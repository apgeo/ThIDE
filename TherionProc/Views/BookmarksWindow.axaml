<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:TherionProc.Services"
        x:Class="TherionProc.Views.BookmarksWindow"
        Title="Bookmarks"
        Width="700" Height="340"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6"
                    Margin="8,6">
            <Button x:Name="DeleteBtn" Content="Delete" Padding="10,3" Click="OnDeleteClick" />
            <Button x:Name="NavigateBtn" Content="Go to" Padding="10,3" Click="OnNavigateClick" />
        </StackPanel>
        <DataGrid x:Name="Grid"
                  x:DataType="services:BookmarkEntry"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Single"
                  AutoGenerateColumns="False"
                  DoubleTapped="OnDoubleTapped">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="140" />
                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="50" />
                <DataGridTextColumn Header="Title" Binding="{Binding DisplayTitle}" Width="*" />
                <DataGridTextColumn Header="Created" Width="130"
                    Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
