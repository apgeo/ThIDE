<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:ed="using:TherionProc.Editor"
             x:Class="TherionProc.Views.Docking.FileDocumentView"
             x:DataType="vm:FileDocumentViewModel">

    <DockPanel>
    <StackPanel DockPanel.Dock="Top">
        <!-- Orphan banner (#4): file not part of the active project's object graph. -->
        <Border Background="#E3F2FD" Padding="10,5" IsVisible="{Binding IsOrphan}">
            <TextBlock Text="{Binding OrphanBannerText}" Foreground="#0D47A1"
                       TextWrapping="Wrap" VerticalAlignment="Center" />
        </Border>

        <!-- Transient info banner (#6): silent reload-from-disk notice. -->
        <Border Background="#E3F2FD" Padding="10,5"
                IsVisible="{Binding InfoBanner, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="6,1"
                        Background="Transparent" BorderThickness="0" Foreground="#0D47A1"
                        Command="{Binding DismissInfoCommand}" />
                <TextBlock Text="{Binding InfoBanner}" Foreground="#0D47A1" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- External-change banner (#6): on-disk change while we have unsaved edits. -->
        <Border Background="#D32F2F" Padding="10,5" IsVisible="{Binding ExternalChangePending}">
            <Grid>
                <!-- Stage 1: changed-on-disk prompt. -->
                <DockPanel IsVisible="{Binding !ConfirmDiscardPending}">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
                        <Button Content="Reload" Padding="8,2" Command="{Binding ReloadExternalCommand}"
                                IsVisible="{Binding !ExternalDeleted}" />
                        <Button Content="Dismiss" Padding="8,2" Command="{Binding DismissExternalCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding ExternalChangeText}" Foreground="White"
                               VerticalAlignment="Center" TextWrapping="Wrap" />
                </DockPanel>
                <!-- Stage 2: discard-unsaved-changes confirmation. -->
                <DockPanel IsVisible="{Binding ConfirmDiscardPending}">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
                        <Button Content="Discard &amp; reload" Padding="8,2"
                                Command="{Binding ConfirmDiscardReloadCommand}" />
                        <Button Content="Keep mine" Padding="8,2" Command="{Binding DismissExternalCommand}" />
                    </StackPanel>
                    <TextBlock Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="Reloading will discard your unsaved changes. Continue?" />
                </DockPanel>
            </Grid>
        </Border>
    </StackPanel>

    <Grid>
    <TabControl>
        <TabItem Header="Source">
            <ed:TherionTextEditor x:Name="Editor"
                                  Text="{Binding DocumentText, Mode=TwoWay}"
                                  Navigation="{Binding Navigation}"
                                  Diagnostics="{Binding Diagnostics}"
                                  CompletionTerms="{Binding CompletionTerms}"
                                  CurrentFilePath="{Binding FilePath}" />
        </TabItem>
        <TabItem Header="Measurements">
            <DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" />
                        <TextBox Width="240"
                                 Text="{Binding Measurements.FilterText, Mode=TwoWay}"
                                 Watermark="from / to / survey / flags / comment" />
                        <TextBlock Text="Group by:" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <ComboBox MinWidth="110"
                                  ItemsSource="{Binding Measurements.GroupByOptions}"
                                  SelectedItem="{Binding Measurements.GroupBy, Mode=TwoWay}" />
                        <TextBlock VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0">
                            <Run Text="{Binding Measurements.Count}" /><Run Text=" of " /><Run Text="{Binding Measurements.TotalCount}" /><Run Text=" shown" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <DataGrid ItemsSource="{Binding Measurements.View}"
                          x:CompileBindings="False"
                          IsReadOnly="True" GridLinesVisibility="All"
                          CanUserSortColumns="True" CanUserResizeColumns="True"
                          CanUserReorderColumns="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Survey"  Binding="{Binding Survey}"  Width="130" />
                        <DataGridTextColumn Header="From"    Binding="{Binding From}"    Width="110"
                                            FontWeight="Bold" Foreground="#1565C0" />
                        <DataGridTextColumn Header="To"      Binding="{Binding To}"      Width="110"
                                            FontWeight="Bold" Foreground="#1565C0" />
                        <DataGridTextColumn Header="Length"  Binding="{Binding Length}"  Width="70"  />
                        <DataGridTextColumn Header="Compass" Binding="{Binding Compass}" Width="80"  />
                        <DataGridTextColumn Header="Clino"   Binding="{Binding Clino}"   Width="70"  />
                        <DataGridCheckBoxColumn Header="Surf"   Binding="{Binding Surface}"     Width="50" />
                        <DataGridCheckBoxColumn Header="Dup"    Binding="{Binding Duplicate}"   Width="50" />
                        <DataGridCheckBoxColumn Header="Splay"  Binding="{Binding Splay}"       Width="55" />
                        <DataGridCheckBoxColumn Header="Approx" Binding="{Binding Approximate}" Width="65" />
                        <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*" />
                        <DataGridTextColumn Header="Line"    Binding="{Binding Line}"    Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>
    </TabControl>

        <!-- File-actions button, overlaid on the tab-strip row (no extra height, #7). -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,6,0"
                Padding="6,2" Background="Transparent" BorderThickness="0" FontSize="14"
                Content="&#x22EF;" ToolTip.Tip="File actions">
            <Button.Flyout>
                <MenuFlyout>
                    <MenuItem Header="Copy File Name" Command="{Binding CopyFileNameCommand}" />
                    <MenuItem Header="Copy Relative Path" Command="{Binding CopyRelativePathCommand}" />
                    <MenuItem Header="Copy Full Path" Command="{Binding CopyFullPathCommand}" />
                </MenuFlyout>
            </Button.Flyout>
        </Button>
    </Grid>
    </DockPanel>
</UserControl>
