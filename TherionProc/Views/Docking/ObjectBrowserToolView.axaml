<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             x:Class="TherionProc.Views.Docking.ObjectBrowserToolView"
             x:DataType="vm:ObjectBrowserToolViewModel">
    <TabControl>
        <TabItem Header="{Binding Browser.TabStations}">
            <DataGrid ItemsSource="{Binding Browser.Stations}" DoubleTapped="OnRowDoubleTapped"
                      IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Qualified name" Binding="{Binding QualifiedName}" Width="*" />
                    <DataGridTextColumn Header="Kind"   Binding="{Binding Kind}"   Width="100" />
                    <DataGridTextColumn Header="Survey" Binding="{Binding Survey}" Width="160" />
                    <DataGridTextColumn Header="Line"   Binding="{Binding Line}"   Width="60"  />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="{Binding Browser.TabShots}">
            <DataGrid ItemsSource="{Binding Browser.Shots}"
                      GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="From"    Binding="{Binding From}"    Width="*"  IsReadOnly="True" />
                    <DataGridTextColumn Header="To"      Binding="{Binding To}"      Width="*"  IsReadOnly="True" />
                    <DataGridTextColumn Header="Length"  Binding="{Binding Length,  Mode=TwoWay}" Width="80" />
                    <DataGridTextColumn Header="Compass" Binding="{Binding Compass, Mode=TwoWay}" Width="80" />
                    <DataGridTextColumn Header="Clino"   Binding="{Binding Clino,   Mode=TwoWay}" Width="80" />
                    <DataGridTextColumn Header="Line"    Binding="{Binding Line}"    Width="60" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <!-- DATA-03 — entity tabs -->
        <TabItem Header="Surveys">
            <DataGrid ItemsSource="{Binding Browser.Surveys}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="Parent" Binding="{Binding Parent}" Width="160" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="140" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Fixes">
            <DataGrid ItemsSource="{Binding Browser.Fixes}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Station" Binding="{Binding Station}" Width="*" />
                    <DataGridTextColumn Header="Coordinates" Binding="{Binding Coordinates}" Width="220" />
                    <DataGridTextColumn Header="CRS" Binding="{Binding Cs}" Width="90" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="140" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Equates">
            <DataGrid ItemsSource="{Binding Browser.Equates}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Equate" Binding="{Binding Stations}" Width="*" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="140" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Maps">
            <DataGrid ItemsSource="{Binding Browser.Maps}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="Projection" Binding="{Binding Projection}" Width="100" />
                    <DataGridTextColumn Header="Members" Binding="{Binding Members}" Width="80" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="140" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Scraps">
            <DataGrid ItemsSource="{Binding Browser.Scraps}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" />
                    <DataGridTextColumn Header="Sketch (.xvi)" Binding="{Binding Sketch}" Width="180" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="160" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Points">
            <DataGrid ItemsSource="{Binding Browser.Points}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                    <DataGridTextColumn Header="Scrap" Binding="{Binding Scrap}" Width="160" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="160" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Lines">
            <DataGrid ItemsSource="{Binding Browser.Lines}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                    <DataGridTextColumn Header="Scrap" Binding="{Binding Scrap}" Width="160" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="160" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Areas">
            <DataGrid ItemsSource="{Binding Browser.Areas}" DoubleTapped="OnRowDoubleTapped" IsReadOnly="True" GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                    <DataGridTextColumn Header="Scrap" Binding="{Binding Scrap}" Width="160" />
                    <DataGridTextColumn Header="File" Binding="{Binding File}" Width="160" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
    </TabControl>
</UserControl>
