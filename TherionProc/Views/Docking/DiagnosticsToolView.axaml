<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:l="using:TherionProc.Resources"
             x:Class="TherionProc.Views.Docking.DiagnosticsToolView"
             x:DataType="vm:DiagnosticsToolViewModel">
    <DockPanel>
        <!-- DIAG-09: explanation pane for the selected diagnostic (thbook link + example fix). -->
        <Border DockPanel.Dock="Bottom" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="8,5"
                IsVisible="{Binding Diagnostics.HasExplanation}"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Diagnostics.Selected.Code}" FontWeight="SemiBold" FontSize="11"
                               VerticalAlignment="Center" />
                    <Button Content="Open docs ↗" FontSize="11" Padding="6,1"
                            Command="{Binding Diagnostics.OpenDocsCommand}"
                            IsVisible="{Binding Diagnostics.HasDocLink}" />
                </StackPanel>
                <TextBlock Text="{Binding Diagnostics.SelectedExplanation}" TextWrapping="Wrap" FontSize="12" />
                <Border Background="#22808080" CornerRadius="3" Padding="6,3"
                        IsVisible="{Binding Diagnostics.HasExample}">
                    <TextBlock Text="{Binding Diagnostics.SelectedExample}" FontFamily="Consolas,monospace"
                               FontSize="11" TextWrapping="NoWrap" />
                </Border>
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2" Spacing="6">
            <ToggleButton Content="{l:Loc Diag_ProjectScope}"
                          IsChecked="{Binding Diagnostics.ShowProjectScope, Mode=TwoWay}"
                          ToolTip.Tip="Show diagnostics from all thconfig project files (requires workspace)"
                          Padding="6,2" FontSize="11" />
            <!-- Roll-up of warnings/errors and the number of affected files (#3). -->
            <TextBlock Text="{Binding Diagnostics.SummaryText}" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="11" />
            <!-- Column show/hide + fit, mirroring the Generated Files grid (#3). -->
            <Button Content="{l:Loc Common_Columns}" Padding="6,2" FontSize="11" ToolTip.Tip="Show or hide columns">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Spacing="2" Margin="8">
                            <CheckBox Content="Code"      Tag="Code"      IsChecked="True"  Click="OnToggleColumn" />
                            <CheckBox Content="Severity"  Tag="Severity"  IsChecked="True"  Click="OnToggleColumn" />
                            <CheckBox Content="Message"   Tag="Message"   IsChecked="True"  Click="OnToggleColumn" />
                            <CheckBox Content="File"      Tag="File"      IsChecked="True"  Click="OnToggleColumn" />
                            <CheckBox Content="Path"      Tag="Path"      IsChecked="False" Click="OnToggleColumn" />
                            <CheckBox Content="Line"      Tag="Line"      IsChecked="True"  Click="OnToggleColumn" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button Content="{l:Loc Common_Fit}" Padding="6,2" FontSize="11" Click="OnFitColumns"
                    ToolTip.Tip="Fit all columns to their content" />
        </StackPanel>

        <!-- DIAG-07: search + severity/category filters + suppression. -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,0,4,3" Spacing="6">
            <TextBox Width="180" Watermark="Filter…" FontSize="11" Padding="4,1"
                     Text="{Binding Diagnostics.SearchText, Mode=TwoWay}" />
            <ToggleButton Content="Errors"   IsChecked="{Binding Diagnostics.ShowErrors, Mode=TwoWay}"   Padding="6,2" FontSize="11" />
            <ToggleButton Content="Warnings" IsChecked="{Binding Diagnostics.ShowWarnings, Mode=TwoWay}" Padding="6,2" FontSize="11" />
            <ToggleButton Content="Info"     IsChecked="{Binding Diagnostics.ShowInfos, Mode=TwoWay}"    Padding="6,2" FontSize="11" />
            <ToggleButton Content="References only" IsChecked="{Binding Diagnostics.OnlyReferences, Mode=TwoWay}"
                          ToolTip.Tip="Show only dangling/unresolved reference diagnostics (DIAG-06)"
                          Padding="6,2" FontSize="11" />
            <Button Content="Clear suppressions" Padding="6,2" FontSize="11"
                    Command="{Binding Diagnostics.ClearSuppressionsCommand}"
                    IsVisible="{Binding Diagnostics.HasSuppressions}" />
        </StackPanel>

        <DataGrid x:Name="Grid"
                  ItemsSource="{Binding Diagnostics.Rows}"
                  SelectedItem="{Binding Diagnostics.Selected, Mode=TwoWay}"
                  x:CompileBindings="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False"
                  DoubleTapped="OnRowDoubleTapped">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{l:Loc Common_Copy}" Click="OnCopyRow" />
                    <MenuItem Header="{l:Loc Common_CopyAll}" Click="OnCopyAll" />
                    <Separator />
                    <MenuItem Header="Explain (open docs)" Command="{Binding Diagnostics.OpenDocsCommand}"
                              IsVisible="{Binding Diagnostics.HasDocLink}" />
                    <MenuItem Header="Suppress this code" Command="{Binding Diagnostics.SuppressSelectedCodeCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <!-- Columns auto-size to fit their header + content; Message takes the remaining
                 space and the long File path is capped with a hover tooltip (#5). -->
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code"     Binding="{Binding Code}"     Width="Auto" MinWidth="70" />
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="Auto" MinWidth="70" />
                <DataGridTemplateColumn Header="Message" Width="*" MinWidth="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" VerticalAlignment="Center" Padding="4,0"
                                       TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Message}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- File name only (shown by default, #3). -->
                <DataGridTemplateColumn Header="File" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" Padding="4,0"
                                       ToolTip.Tip="{Binding File}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Full path (hidden by default; shown in full, not trimmed, #3). -->
                <DataGridTextColumn Header="Path" Binding="{Binding File}" Width="Auto" />
                <DataGridTextColumn Header="Line"     Binding="{Binding Line}"     Width="Auto" MinWidth="48" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
