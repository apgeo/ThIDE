<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:vm2="using:TherionProc.ViewModels"
             xmlns:conv="using:TherionProc.Converters"
             xmlns:l="using:TherionProc.Resources"
             x:Class="TherionProc.Views.Docking.StructuralGeologyToolView"
             x:DataType="vm:StructuralGeologyToolViewModel">

    <!-- STRUCT-01 — plane strike/dip calculator. Tabbed wizard: Detect → Measurements → Planes → Plot.
         Bindings are relative to the tool VM; the content VM is reached via the `Structural.` prefix. -->
    <UserControl.Resources>
        <!-- Cosmetic: show enum options (grouping / splay policy / declination source) as spaced text. -->
        <conv:EnumLabelConverter x:Key="EnumLabel" />
        <!-- #10: measurements grouped by station; each group header carries a master checkbox that
             checks/unchecks the whole station. The header DataContext is the collection-view group;
             its Key is the StructuralPlaneRow (we group by the PlaneRow property). -->
        <ControlTheme x:Key="StationGroupHeaderTheme" TargetType="DataGridRowGroupHeader">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                            Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{ReflectionBinding Key.IncludeAllChecked, Mode=TwoWay}"
                                      ToolTip.Tip="{l:Loc Struct_CheckAllStation}" />
                            <TextBlock Text="{ReflectionBinding Key.Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="{ReflectionBinding ItemCount, StringFormat='({0})'}" Foreground="Gray" VerticalAlignment="Center" FontSize="11" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </UserControl.Resources>

    <DockPanel>
        <!-- Top bar: scope + refresh + status (left), wizard prev/next (right). Shared across tabs. -->
        <Border DockPanel.Dock="Top" Padding="8,5" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
            <DockPanel>
                <!-- #6: hide (not disable) the nav buttons on the first/last tab, keeping their space. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Panel Width="64">
                        <Button Content="{l:Loc Struct_Prev}" Command="{Binding Structural.GoPrevCommand}" Padding="8,2" FontSize="11"
                                IsVisible="{Binding Structural.CanGoPrev}" ToolTip.Tip="{l:Loc Struct_PrevTip}" />
                    </Panel>
                    <Panel Width="64">
                        <Button Content="{l:Loc Struct_Next}" Command="{Binding Structural.GoNextCommand}" Padding="8,2" FontSize="11"
                                IsVisible="{Binding Structural.CanGoNext}" ToolTip.Tip="{l:Loc Struct_NextTip}" />
                    </Panel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{l:Loc Struct_Scope}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" />
                    <RadioButton Content="{l:Loc Struct_ActiveFile}" GroupName="scope" FontSize="11"
                                 IsChecked="{Binding !Structural.ProjectScope}" />
                    <RadioButton Content="{l:Loc Struct_WholeProject}" GroupName="scope" FontSize="11"
                                 IsChecked="{Binding Structural.ProjectScope}" />
                    <Button Content="{l:Loc Struct_Detect}" Command="{Binding Structural.RefreshCommand}" Padding="8,2" FontSize="11" />
                    <TextBlock Text="{Binding Structural.Status}" VerticalAlignment="Center"
                               FontSize="11" Foreground="Gray" TextWrapping="NoWrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Name="Wizard" SelectedIndex="{Binding Structural.SelectedTab}" Padding="6"
                    SelectionChanged="OnTabChanged">

            <!-- 1 · Detect -->
            <TabItem Header="{l:Loc Struct_Tab1}">
                <ScrollViewer>
                    <StackPanel Margin="6" Spacing="10" MaxWidth="560" HorizontalAlignment="Left">

                        <TextBlock Text="{l:Loc Struct_DetectionSignals}" FontWeight="SemiBold" />
                        <TextBlock Text="{l:Loc Struct_DetectionHelp}"
                                   Foreground="Gray" TextWrapping="Wrap" FontSize="11" />

                        <CheckBox Content="{l:Loc Struct_FromNameKeyword}" IsChecked="{Binding Structural.UseNameKeyword}" />
                        <TextBox Text="{Binding Structural.NameKeywords}" Watermark="geo" Margin="22,0,0,0"
                                 IsEnabled="{Binding Structural.UseNameKeyword}" />

                        <CheckBox Content="{l:Loc Struct_CommentMarker}" IsChecked="{Binding Structural.MatchComment}" />
                        <TextBox Text="{Binding Structural.CommentMarkers}" Watermark="plane, geo" Margin="22,0,0,0"
                                 IsEnabled="{Binding Structural.MatchComment}" />

                        <CheckBox Content="{l:Loc Struct_StationFlag}" IsChecked="{Binding Structural.MatchStationFlag}" />
                        <TextBox Text="{Binding Structural.StationFlags}" Watermark="e.g. geo" Margin="22,0,0,0"
                                 IsEnabled="{Binding Structural.MatchStationFlag}" />

                        <TextBlock Text="{l:Loc Struct_GroupingPoints}" FontWeight="SemiBold" Margin="0,8,0,0" />

                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Struct_GroupPlaneBy}" VerticalAlignment="Center" FontSize="12" />
                            <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Structural.GroupingModes}"
                                      SelectedItem="{Binding Structural.Grouping}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Converter={StaticResource EnumLabel}}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Struct_SplayShots}" VerticalAlignment="Center" FontSize="12" />
                            <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Structural.SplayPolicies}"
                                      SelectedItem="{Binding Structural.Splays}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Converter={StaticResource EnumLabel}}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <CheckBox Content="{l:Loc Struct_IncludeOrigin}"
                                  IsChecked="{Binding Structural.IncludeOriginPoint}" />
                        <TextBlock Text="{l:Loc Struct_IncludeOriginHelp}"
                                   Foreground="Gray" TextWrapping="Wrap" FontSize="11" Margin="22,0,0,0" />

                        <TextBlock Text="{l:Loc Struct_MagDeclination}" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Struct_Source}" VerticalAlignment="Center" FontSize="12" />
                            <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Structural.DeclinationSources}"
                                      SelectedItem="{Binding Structural.DeclinationSource}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Converter={StaticResource EnumLabel}}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Struct_ValueEast}" VerticalAlignment="Center" FontSize="12"
                                       IsVisible="{Binding Structural.DeclinationIsManual}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Structural.DeclinationDegrees}"
                                     IsVisible="{Binding Structural.DeclinationIsManual}" Watermark="0.0" />
                        </Grid>
                        <TextBlock Text="{l:Loc Struct_DeclinationHelp}"
                                   Foreground="Gray" TextWrapping="Wrap" FontSize="11" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2 · Measurements -->
            <TabItem Header="{l:Loc Struct_Tab2}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="2,2,2,4">
                        <Button Command="{Binding Structural.CheckAllCommand}" Padding="6,2" FontSize="12"
                                ToolTip.Tip="{l:Loc Struct_CheckAll}" Content="{l:Loc Struct_All}" />
                        <Button Command="{Binding Structural.CheckNoneCommand}" Padding="6,2" FontSize="12"
                                ToolTip.Tip="{l:Loc Struct_CheckNone}" Content="{l:Loc Struct_NoneBtn}" />
                        <Button Command="{Binding Structural.InvertSelectionCommand}" Padding="6,2" FontSize="12"
                                ToolTip.Tip="{l:Loc Struct_InvertSel}" Content="{l:Loc Struct_Invert}" />
                        <CheckBox Content="{l:Loc Struct_GroupByStation}" Margin="10,0,0,0" FontSize="11" VerticalAlignment="Center"
                                  IsChecked="{Binding Structural.GroupByStation}" />
                        <!-- Full station name toggle (identical behaviour to the .th editor's measurements tab). -->
                        <ToggleButton Padding="6,3" VerticalAlignment="Center" Margin="6,0,0,0"
                                      ToolTip.Tip="{l:Loc Common_FullStationName}"
                                      IsChecked="{Binding Structural.ShowFullStationName, Mode=TwoWay}">
                            <PathIcon Data="{DynamicResource Icon.NodeGraph}" Width="14" Height="14" />
                        </ToggleButton>
                        <Button Content="{l:Loc Common_Columns}" Padding="6,2" FontSize="11" ToolTip.Tip="{l:Loc Common_ShowHideColumns}">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Name="MeasColumnsPanel" Spacing="2">
                                        <CheckBox Content="{l:Loc Struct_Col_Use}"    Tag="Use"     Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_Plane}"  Tag="Plane"   Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_Kind}"  Tag="Kind"    Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_From}"  Tag="From"    Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_To}"    Tag="To"      Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_Length}" Tag="Length" Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_Azimuth}" Tag="Azimuth" Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_Clino}" Tag="Clino"   Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Common_Comment}"    Tag="Comment" Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Common_File}"       Tag="File"    Click="OnToggleMeasColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_Line}"  Tag="Line"    Click="OnToggleMeasColumn" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Content="{l:Loc Common_FitPlain}" Padding="6,2" FontSize="11" Click="OnFitMeasColumns" ToolTip.Tip="{l:Loc Common_AutoSize}" />
                        <Button Content="{l:Loc Common_ExportCsv}" Padding="6,2" FontSize="11" Click="OnExportMeasCsv"
                                ToolTip.Tip="{l:Loc Struct_ExportMeasTip}" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="2,2,2,6" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                               Text="{l:Loc Struct_MeasHelp}" />
                    <!-- ItemsSource (a grouped DataGridCollectionView) is set in code-behind so grouping can toggle. -->
                    <DataGrid Name="MeasurementsGrid"
                              IsReadOnly="False" CanUserSortColumns="True" CanUserResizeColumns="True"
                              SelectionMode="Extended"
                              GridLinesVisibility="Horizontal" DoubleTapped="OnMeasurementDoubleTapped"
                              RowGroupTheme="{StaticResource StationGroupHeaderTheme}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{l:Loc Common_CopyValue}" Click="OnCopyMeasValue" />
                                <MenuItem Header="{l:Loc Common_CopyRow}" Click="OnCopyMeasRow" />
                                <MenuItem Header="{l:Loc Common_CopyFormatted}" Click="OnCopyMeasFormatted" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <!-- ReflectionBinding: ItemsSource is a (non-generic) grouped view set in code-behind,
                             so columns resolve against the row item at runtime, not the UserControl's x:DataType.
                             Column order MUST stay in sync with MeasColOrder in the code-behind. -->
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="{l:Loc Struct_Col_Use}" Binding="{ReflectionBinding Include}" Width="Auto" MinWidth="40" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Plane}" Binding="{ReflectionBinding Plane}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_Kind}" Binding="{ReflectionBinding Kind}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_From}" Binding="{ReflectionBinding From}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_To}" Binding="{ReflectionBinding To}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_Length}" Binding="{ReflectionBinding Length}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Azimuth}" Binding="{ReflectionBinding Compass}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_Clino}" Binding="{ReflectionBinding Clino}" IsReadOnly="True" Width="Auto" />
                            <!-- Comment clipped to ~25 chars (full text in the tooltip); keeps Fit from ballooning. -->
                            <DataGridTemplateColumn Header="{l:Loc Common_Comment}" IsReadOnly="True" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{ReflectionBinding CommentShort}" VerticalAlignment="Center"
                                                   Padding="4,0" ToolTip.Tip="{ReflectionBinding Comment}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{l:Loc Common_File}" Binding="{ReflectionBinding File}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_Line}" Binding="{ReflectionBinding Line}" IsReadOnly="True" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- 3 · Resulted planes -->
            <TabItem Header="{l:Loc Struct_Tab3}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="2,2,2,4">
                        <!-- Plot visibility bulk toggles (mirror the measurements grid's All/None/Invert). -->
                        <TextBlock Text="{l:Loc Struct_VisibleLabel}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="0,0,2,0" />
                        <Button Content="{l:Loc Struct_All}" Command="{Binding Structural.ShowAllPlanesCommand}" Padding="6,2" FontSize="12"
                                ToolTip.Tip="{l:Loc Struct_ShowAllPlanes}" />
                        <Button Content="{l:Loc Struct_NoneBtn}" Command="{Binding Structural.HideAllPlanesCommand}" Padding="6,2" FontSize="12"
                                ToolTip.Tip="{l:Loc Struct_HideAllPlanes}" />
                        <Button Content="{l:Loc Struct_Invert}" Command="{Binding Structural.InvertPlaneVisibilityCommand}" Padding="6,2" FontSize="12"
                                ToolTip.Tip="{l:Loc Struct_InvertPlanes}" />
                        <Border Width="1" Margin="6,2" Background="Gray" />
                        <Button Content="{l:Loc Common_Columns}" Padding="6,2" FontSize="11" ToolTip.Tip="{l:Loc Common_ShowHideColumns}">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Name="PlaneColumnsPanel" Spacing="2">
                                        <CheckBox Content="{l:Loc Struct_Col_Plane}"    Tag="Plane"      Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_Dip}"      Tag="Dip °"      Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_Strike}"   Tag="Strike °"   Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_DipDir}"   Tag="Dip dir °"  Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_NorthRef}" Tag="North ref"  Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_Points}"   Tag="Points"     Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Struct_Col_Rms}"      Tag="RMS"        Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Common_File}"         Tag="File"       Click="OnTogglePlaneColumn" />
                                        <CheckBox Content="{l:Loc Browser_Col_Line}"    Tag="Line"       Click="OnTogglePlaneColumn" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Content="{l:Loc Common_FitPlain}" Padding="6,2" FontSize="11" Click="OnFitPlaneColumns" ToolTip.Tip="{l:Loc Common_AutoSize}" />
                        <Button Content="{l:Loc Common_ExportCsv}" Padding="6,2" FontSize="11" Click="OnExportPlanesCsv"
                                ToolTip.Tip="{l:Loc Struct_ExportPlanesTip}" />
                    </StackPanel>
                    <DataGrid Name="PlanesGrid" ItemsSource="{Binding Structural.Planes}"
                              SelectedItem="{Binding Structural.SelectedPlane}"
                              IsReadOnly="True" CanUserSortColumns="True" CanUserResizeColumns="True"
                              SelectionMode="Extended"
                              GridLinesVisibility="Horizontal" DoubleTapped="OnPlaneDoubleTapped">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{l:Loc Common_CopyValue}" Click="OnCopyPlaneValue" />
                                <MenuItem Header="{l:Loc Common_CopyRow}" Click="OnCopyPlaneRow" />
                                <MenuItem Header="{l:Loc Common_CopyFormatted}" Click="OnCopyPlaneFormatted" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <!-- Column order MUST stay in sync with PlaneColOrder in the code-behind. -->
                        <DataGrid.Columns>
                            <!-- Checkbox works even though the grid is read-only (template control, not a cell editor). -->
                            <DataGridTemplateColumn Header="{l:Loc Struct_Col_Visible}" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Visible, Mode=TwoWay}" HorizontalAlignment="Center"
                                                  ToolTip.Tip="{l:Loc Struct_PlaneDiscTip}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Plane}" Binding="{Binding Name}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Dip}" Binding="{Binding Dip}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Strike}" Binding="{Binding Strike}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_DipDir}" Binding="{Binding DipDirection}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_NorthRef}" Binding="{Binding Declination}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Points}" Binding="{Binding Points}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Struct_Col_Rms}" Binding="{Binding Quality}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Common_File}" Binding="{Binding File}" Width="Auto" />
                            <DataGridTextColumn Header="{l:Loc Browser_Col_Line}" Binding="{Binding Line}" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- 4 · Plot -->
            <TabItem Header="{l:Loc Struct_Tab4}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="2">
                        <Button Content="{l:Loc Struct_FitView}" Click="OnFitView" Padding="8,2" FontSize="11" />
                        <Button Content="{l:Loc Struct_ExportImage}" Click="OnExportImage" Padding="8,2" FontSize="11"
                                ToolTip.Tip="{l:Loc Struct_ExportImageTip}" />
                        <TextBlock Text="{l:Loc Struct_DiscSize}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" />
                        <ComboBox ItemsSource="{Binding Structural.DiscScales}"
                                  SelectedItem="{Binding Structural.DiscScale}" FontSize="11" MinWidth="64"
                                  ToolTip.Tip="{l:Loc Struct_DiscSizeTip}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding StringFormat='{}{0}×'}" /></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox Content="{l:Loc Struct_WhiteBackground}" FontSize="11" VerticalAlignment="Center"
                                  IsChecked="{Binding Structural.WhiteBackground}" />
                    </StackPanel>
                    <Panel>
                        <Panel Name="PlotHost" />
                        <Border Name="PlotFallback" IsVisible="False"
                                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="24" Foreground="Gray" TextAlignment="Center"
                                       Text="{l:Loc Struct_PlotFallback}" />
                        </Border>
                    </Panel>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
