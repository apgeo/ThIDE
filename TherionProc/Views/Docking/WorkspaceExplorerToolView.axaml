<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:vmw="using:TherionProc.ViewModels"
             xmlns:conv="using:TherionProc.Converters"
             x:Class="TherionProc.Views.Docking.WorkspaceExplorerToolView"
             x:DataType="vm:WorkspaceExplorerToolViewModel">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel Spacing="4">
                <TextBlock Foreground="Gray" Text="{Binding Explorer.RootPath}"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <CheckBox Content="Object model" FontSize="11" VerticalAlignment="Center"
                              IsChecked="{Binding Explorer.ShowObjectModel, Mode=TwoWay}" />
                    <ToggleButton Padding="5,1" FontSize="13" VerticalAlignment="Center"
                                  ToolTip.Tip="Highlight workspace item when hovering a link in the editor"
                                  IsChecked="{Binding Explorer.RevealOnHover, Mode=TwoWay}" Content="&#x1F50D;" />
                    <ToggleButton Padding="5,1" FontSize="13" VerticalAlignment="Center"
                                  ToolTip.Tip="Highlight the active file in the workspace when switching tabs"
                                  IsChecked="{Binding Explorer.RevealOnTabSwitch, Mode=TwoWay}" Content="&#x21C6;" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TreeView x:Name="Tree" x:CompileBindings="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ItemsSource="{Binding Explorer.Roots}"
                  SelectedItem="{Binding Explorer.Selected, Mode=TwoWay}"
                  DoubleTapped="OnNodeDoubleTapped">
            <TreeView.Styles>
                <!-- Honor each node's default-expansion state. -->
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="6" ToolTip.Tip="{Binding Name}">
                        <PathIcon Data="{Binding Kind, Converter={x:Static conv:KindToIconConverter.Instance}}"
                                  Foreground="{Binding IconBrush}" Width="14" Height="14"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Detail}" Foreground="Gray" FontStyle="Italic"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
