<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:vmw="using:TherionProc.ViewModels"
             xmlns:conv="using:TherionProc.Converters"
             x:Class="TherionProc.Views.Docking.WorkspaceExplorerToolView"
             x:DataType="vm:WorkspaceExplorerToolViewModel">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel Spacing="5">
                <!-- View-mode switch (#5): relational object graph vs. file explorer. -->
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <ToggleButton Padding="6,3" ToolTip.Tip="Relational object-graph view"
                                  IsChecked="{Binding Explorer.IsRelationalView, Mode=OneWay}"
                                  Command="{Binding Explorer.SwitchToRelationalCommand}">
                        <PathIcon Data="{DynamicResource Icon.Cube}" Width="14" Height="14" />
                    </ToggleButton>
                    <ToggleButton Padding="6,3" ToolTip.Tip="File-explorer view"
                                  IsChecked="{Binding Explorer.IsFileExplorerView, Mode=OneWay}"
                                  Command="{Binding Explorer.SwitchToFileExplorerCommand}">
                        <PathIcon Data="{DynamicResource Icon.Folder}" Width="14" Height="14" />
                    </ToggleButton>
                </StackPanel>

                <!-- Active thconfig dropdown (#3) + its formatted path (#8). -->
                <ComboBox HorizontalAlignment="Stretch" FontSize="11" x:CompileBindings="False"
                          ToolTip.Tip="Active configuration (drives the object graph)"
                          ItemsSource="{Binding Explorer.ThconfigCandidates}"
                          SelectedItem="{Binding Explorer.SelectedThconfig, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayPath}" ToolTip.Tip="{Binding FullPath}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <!-- Show file nodes in the relational view (#5a); hidden in file-explorer mode. -->
                    <ToggleButton Padding="5,3" VerticalAlignment="Center"
                                  ToolTip.Tip="Show file nodes in the object graph"
                                  IsVisible="{Binding Explorer.IsRelationalView}"
                                  IsChecked="{Binding Explorer.ShowFilesInModel, Mode=TwoWay}">
                        <PathIcon Data="{DynamicResource Icon.File}" Width="14" Height="14" />
                    </ToggleButton>
                    <ToggleButton Padding="5,3" VerticalAlignment="Center"
                                  ToolTip.Tip="Highlight workspace item when hovering a link in the editor"
                                  IsChecked="{Binding Explorer.RevealOnHover, Mode=TwoWay}">
                        <PathIcon Data="{DynamicResource Icon.Eye}" Width="14" Height="14" />
                    </ToggleButton>
                    <ToggleButton Padding="5,3" VerticalAlignment="Center"
                                  ToolTip.Tip="Highlight the active file in the workspace when switching tabs"
                                  IsChecked="{Binding Explorer.RevealOnTabSwitch, Mode=TwoWay}">
                        <PathIcon Data="{DynamicResource Icon.Swap}" Width="14" Height="14" />
                    </ToggleButton>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- File-modified-outside-editor banner (#5b). -->
        <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="8,4"
                IsVisible="{Binding Explorer.WorkspaceBanner, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="6,0"
                        Background="Transparent" BorderThickness="0" Foreground="#0D47A1"
                        Command="{Binding Explorer.DismissWorkspaceBannerCommand}" />
                <TextBlock Text="{Binding Explorer.WorkspaceBanner}" Foreground="#0D47A1"
                           VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11" />
            </DockPanel>
        </Border>

        <TreeView x:Name="Tree" x:CompileBindings="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ItemsSource="{Binding Explorer.Roots}"
                  SelectedItem="{Binding Explorer.Selected, Mode=TwoWay}"
                  ContextRequested="OnTreeContextRequested"
                  DoubleTapped="OnNodeDoubleTapped">
            <TreeView.Styles>
                <!-- Honor each node's default-expansion state. -->
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <!-- Border carries the yellow hover-highlight (#4) and the hover tooltip (#2). -->
                    <Border Background="{Binding RowBackground}" CornerRadius="2" Padding="2,0">
                        <Border.ContextMenu>
                            <ContextMenu Opening="OnContextMenuOpening">
                                <MenuItem Header="Open" Click="OnCtxOpen" />
                                <MenuItem Header="Reveal in File Explorer" Click="OnCtxReveal" />
                                <Separator />
                                <MenuItem Header="New File…" Click="OnCtxNewFile" />
                                <MenuItem Header="New Folder…" Click="OnCtxNewFolder" />
                                <!-- Shown on every OS; header is set per-platform in OnContextMenuOpening. -->
                                <MenuItem Header="Delete" Tag="delete" Click="OnCtxDelete" />
                                <Separator />
                                <MenuItem Header="Copy Full Path" Click="OnCtxCopyFull" />
                                <MenuItem Header="Copy Relative Path" Click="OnCtxCopyRel" />
                                <Separator />
                                <MenuItem Header="Refresh" Click="OnCtxRefresh" />
                                <!-- Visible only where a native shell menu exists (INativeContextMenuService). -->
                                <MenuItem Header="More options (Windows shell)…" Tag="nativemenu" Click="OnCtxShellMenu" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <ToolTip.Tip>
                            <StackPanel MaxWidth="600">
                                <TextBlock Text="{Binding TooltipTitle}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LastModifiedText}" Foreground="Gray" FontSize="11"
                                           IsVisible="{Binding LastModifiedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </ToolTip.Tip>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Native shell icon (file-explorer view) with a glyph fallback. -->
                            <Image Source="{Binding ShellIcon}" Width="16" Height="16" VerticalAlignment="Center"
                                   IsVisible="{Binding ShellIcon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <PathIcon Data="{Binding Kind, Converter={x:Static conv:KindToIconConverter.Instance}}"
                                      Foreground="{Binding IconBrush}" Width="14" Height="14" VerticalAlignment="Center"
                                      IsVisible="{Binding ShellIcon, Converter={x:Static ObjectConverters.IsNull}}" />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Detail}" Foreground="Gray" FontStyle="Italic"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
