<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:conv="using:TherionProc.Converters"
             xmlns:l="using:TherionProc.Resources"
             x:Class="TherionProc.Views.Docking.GeneratedFilesToolView"
             x:DataType="vm:GeneratedFilesToolViewModel">
    <DockPanel>
        <!-- BUILD-03: stale-output banner (an input changed since the last build). -->
        <Border DockPanel.Dock="Top" Background="#33E65100" Padding="8,4"
                IsVisible="{Binding Build.HasStaleArtifacts}">
            <TextBlock Text="⚠ Some outputs are out of date — a project input changed since the last build. Rebuild to refresh."
                       Foreground="#E65100" FontSize="11" TextWrapping="Wrap" />
        </Border>
        <!-- Column visibility + fit controls (#4). -->
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,3">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="{l:Loc Common_Columns}" Padding="6,2" FontSize="11" ToolTip.Tip="Show or hide columns">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Spacing="2" Margin="8">
                                <CheckBox Content="Kind"      Tag="Kind"      IsChecked="True"  Click="OnToggleColumn" />
                                <CheckBox Content="File Name" Tag="File Name" IsChecked="True"  Click="OnToggleColumn" />
                                <CheckBox Content="Path"      Tag="Path"      IsChecked="False" Click="OnToggleColumn" />
                                <CheckBox Content="Size"      Tag="Size"      IsChecked="True"  Click="OnToggleColumn" />
                                <CheckBox Content="Modified"  Tag="Modified"  IsChecked="True"  Click="OnToggleColumn" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Content="{l:Loc Common_Fit}" Padding="6,2" FontSize="11" Click="OnFitColumns"
                        ToolTip.Tip="Fit all columns to their content" />
            </StackPanel>
        </Border>

        <DataGrid x:Name="Grid"
                  ItemsSource="{Binding Build.Artifacts}"
                  SelectedItem="{Binding Build.SelectedArtifact, Mode=TwoWay}"
                  x:CompileBindings="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True" CanUserSortColumns="True" AutoGenerateColumns="False"
                  DoubleTapped="OnArtifactDoubleTapped">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{l:Loc Common_Open}" Click="OnOpenArtifact" />
                    <MenuItem Header="{l:Loc Gen_Reveal}" Click="OnRevealArtifact" />
                    <Separator />
                    <MenuItem Header="{l:Loc Gen_GoToDef}" Click="OnGoToArtifactDefinition" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <!-- Kind with a per-type icon (#4). -->
                <DataGridTemplateColumn Header="Kind" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0" VerticalAlignment="Center">
                                <PathIcon Width="13" Height="13"
                                          Data="{Binding IconKey, Converter={x:Static conv:ResourceKeyToGeometryConverter.Instance}}" />
                                <TextBlock Text="{Binding Kind}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="Auto" />
                <!-- BUILD-03: current / stale state. -->
                <DataGridTextColumn Header="State" Binding="{Binding StateText}" Width="Auto" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="Auto" />
                <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedDisplay}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
