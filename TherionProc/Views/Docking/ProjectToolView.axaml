<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             x:Class="TherionProc.Views.Docking.ProjectToolView"
             x:CompileBindings="False"
             x:DataType="vm:ProjectToolViewModel">
    <UserControl.Styles>
        <!-- Flat clickable row used by the audit lists. -->
        <Style Selector="Button.row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="TextBlock.h">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
        <Style Selector="TextBlock.k">
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="Width" Value="130" />
        </Style>
    </UserControl.Styles>

    <TabControl>
        <!-- PROJ-07 — Dashboard -->
        <TabItem Header="Dashboard">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12" Spacing="4">
                    <TextBlock Text="{Binding Dashboard.ProjectName}" FontSize="18" FontWeight="Bold" />
                    <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="k" Text="Entry config" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Dashboard.EntryConfig}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="k" Text="Files" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Dashboard.FileSummary}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="k" Text="Surveys" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Dashboard.SurveySummary}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="k" Text="Stations" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Dashboard.StationsText}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="k" Text="Total length" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Dashboard.LengthText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="k" Text="Depth" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Dashboard.DepthText}" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Classes="k" Text="Entrances" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Dashboard.EntrancesText}" />
                        <TextBlock Grid.Row="7" Grid.Column="0" Classes="k" Text="Diagnostics" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Dashboard.DiagnosticsText}" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,12" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="k" Text="Last build" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Dashboard.BuildStatus}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Classes="h" Text="Quick actions" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Build" Command="{Binding Dashboard.Build.BuildCommand}" />
                        <Button Content="Open output folder" Command="{Binding Dashboard.Build.OpenLastOutputFolderCommand}" />
                        <Button Content="Refresh" Command="{Binding Dashboard.RefreshCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- PROJ-03 — Survey tree -->
        <TabItem Header="Surveys">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Margin="8,6" Foreground="Gray"
                           Text="No surveys in the project yet."
                           IsVisible="{Binding Surveys.IsEmpty}" />
                <TreeView ItemsSource="{Binding Surveys.Roots}"
                          SelectedItem="{Binding Surveys.Selected, Mode=TwoWay}">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="▣" Foreground="#1565C0" />
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="{Binding Counts}" Foreground="Gray" FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </TabItem>

        <!-- DATA-01 — Statistics -->
        <TabItem Header="Statistics">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,6">
                    <Button Content="Refresh" Command="{Binding Analytics.RefreshCommand}" />
                    <Button Content="Copy" Command="{Binding Analytics.CopyStatisticsCommand}" />
                    <TextBlock Text="{Binding Analytics.Summary}" Foreground="Gray" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Analytics.Statistics}" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" AutoGenerateColumns="False" HeadersVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Label}" Width="220" />
                        <DataGridTextColumn Binding="{Binding Value}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <!-- DATA-02 — Charts -->
        <TabItem Header="Charts">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" Spacing="2">
                    <TextBlock Classes="h" Text="Length by survey (top 30)" />
                    <ItemsControl ItemsSource="{Binding Analytics.LengthBySurvey}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="180,*,90" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1" Background="#3949AB" Height="12" HorizontalAlignment="Left"
                                            Width="{Binding BarWidth}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right" Foreground="Gray" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="h" Text="Length by date" />
                    <ItemsControl ItemsSource="{Binding Analytics.LengthByDate}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="180,*,90" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1" Background="#00897B" Height="12" HorizontalAlignment="Left"
                                            Width="{Binding BarWidth}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right" Foreground="Gray" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- DATA-05 — Team & expeditions -->
        <TabItem Header="Team">
            <DockPanel>
                <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="8,6"
                        Content="Copy team (CSV)" Command="{Binding Analytics.CopyTeamCommand}" />
                <Grid RowDefinitions="*,Auto,*">
                    <DataGrid Grid.Row="0" ItemsSource="{Binding Analytics.Team}" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Person" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Surveys" Binding="{Binding Surveys}" Width="80" />
                            <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1" Classes="h" Text="Expeditions (by date)" Margin="8,6,0,3" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Analytics.Expeditions}" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120" />
                            <DataGridTextColumn Header="Surveys" Binding="{Binding Surveys}" Width="80" />
                            <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="100" />
                            <DataGridTextColumn Header="Members" Binding="{Binding Members}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </DockPanel>
        </TabItem>

        <!-- DATA-06 — Entrances & fixed points -->
        <TabItem Header="Entrances">
            <DockPanel>
                <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="8,6"
                        Content="Copy (CSV)" Command="{Binding Analytics.CopyFixedPointsCommand}" />
                <DataGrid ItemsSource="{Binding Analytics.FixedPoints}" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" CanUserSortColumns="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Station" Binding="{Binding Station}" Width="*" />
                        <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="120" />
                        <DataGridTextColumn Header="Coordinates" Binding="{Binding Coordinates}" Width="220" />
                        <DataGridTextColumn Header="CRS" Binding="{Binding Cs}" Width="90" />
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <!-- DATA-08 — Data quality -->
        <TabItem Header="Quality">
            <DataGrid ItemsSource="{Binding Analytics.Quality}" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="*" />
                    <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <!-- PROJ-02 — Orphan / dead-file audit -->
        <TabItem Header="Audit">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,6">
                    <Button Content="Re-scan" Command="{Binding Audit.RefreshCommand}" />
                    <TextBlock Text="{Binding Audit.Summary}" Foreground="Gray" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,0,8,8">
                        <TextBlock Classes="h" Text="Orphan files (not reachable from any entry point)" />
                        <ItemsControl ItemsSource="{Binding Audit.OrphanFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="row" Command="{Binding $parent[ItemsControl].DataContext.Audit.OpenCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Title}" />
                                            <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Classes="h" Text="Unreferenced scraps (not in any map)" />
                        <ItemsControl ItemsSource="{Binding Audit.UnreferencedScraps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="row" Command="{Binding $parent[ItemsControl].DataContext.Audit.OpenCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Title}" />
                                            <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Classes="h" Text="Unexported maps (declared but not selected)" />
                        <ItemsControl ItemsSource="{Binding Audit.UnexportedMaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="row" Command="{Binding $parent[ItemsControl].DataContext.Audit.OpenCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Title}" />
                                            <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <!-- LEAD-01/03/05 — exploration leads register -->
        <TabItem Header="Leads">
            <DockPanel>
                <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6" VerticalAlignment="Center">
                    <Button Content="Re-scan" Command="{Binding Leads.RefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="Go to source" Command="{Binding Leads.OpenCommand}"
                            CommandParameter="{Binding #LeadsGrid.SelectedItem}" Margin="0,0,6,0" />
                    <Button Content="Checked" Command="{Binding Leads.MarkCheckedCommand}"
                            CommandParameter="{Binding #LeadsGrid.SelectedItem}" Margin="0,0,6,0" />
                    <Button Content="Pushed" Command="{Binding Leads.MarkPushedCommand}"
                            CommandParameter="{Binding #LeadsGrid.SelectedItem}" Margin="0,0,6,0" />
                    <Button Content="Dead" Command="{Binding Leads.MarkDeadCommand}"
                            CommandParameter="{Binding #LeadsGrid.SelectedItem}" Margin="0,0,6,0" />
                    <Button Content="Open" Command="{Binding Leads.MarkOpenCommand}"
                            CommandParameter="{Binding #LeadsGrid.SelectedItem}" Margin="0,0,6,0" />
                    <Button Content="Copy as Markdown" Command="{Binding Leads.CopyAsMarkdownCommand}" Margin="0,0,12,0" />
                    <TextBlock Text="{Binding Leads.Summary}" Foreground="Gray" VerticalAlignment="Center" />
                </WrapPanel>
                <DataGrid x:Name="LeadsGrid" ItemsSource="{Binding Leads.Leads}" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" CanUserResizeColumns="True"
                          CanUserSortColumns="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*" />
                        <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="150" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="File" Binding="{Binding File}" Width="140" />
                        <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <!-- NOTE-01 — TODO / FIXME / QM aggregator -->
        <TabItem Header="TODOs">
            <DockPanel>
                <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6" VerticalAlignment="Center">
                    <Button Content="Re-scan" Command="{Binding Todos.RefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="Go to source" Command="{Binding Todos.OpenCommand}"
                            CommandParameter="{Binding #TodosGrid.SelectedItem}" Margin="0,0,6,0" />
                    <Button Content="Copy as Markdown" Command="{Binding Todos.CopyAsMarkdownCommand}" Margin="0,0,12,0" />
                    <TextBlock Text="{Binding Todos.Summary}" Foreground="Gray" VerticalAlignment="Center" />
                </WrapPanel>
                <DataGrid x:Name="TodosGrid" ItemsSource="{Binding Todos.Todos}" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" CanUserResizeColumns="True"
                          CanUserSortColumns="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="90" />
                        <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*" />
                        <DataGridTextColumn Header="File" Binding="{Binding File}" Width="160" />
                        <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <!-- NOTE-04 — project metadata editor -->
        <TabItem Header="Metadata">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" Spacing="8" MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="Project metadata (stored in a sidecar, not in the .th source)."
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          IsEnabled="{Binding Metadata.HasProject}">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Metadata.Name}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Region" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Metadata.Region}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="CRS" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Metadata.Crs}" Watermark="e.g. EPSG:3844" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Declination source" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Metadata.DeclinationSource}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="License" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Metadata.License}" />
                    </Grid>
                    <TextBlock Text="Notes" />
                    <TextBox Text="{Binding Metadata.Notes}" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="80" IsEnabled="{Binding Metadata.HasProject}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save" Command="{Binding Metadata.SaveCommand}"
                                IsEnabled="{Binding Metadata.HasProject}" />
                        <Button Content="Reload" Command="{Binding Metadata.ReloadCommand}" />
                        <TextBlock Text="{Binding Metadata.Status}" Foreground="Gray" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
