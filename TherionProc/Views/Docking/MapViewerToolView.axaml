<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TherionProc.ViewModels.Docking"
             xmlns:l="using:TherionProc.Resources"
             x:Class="TherionProc.Views.Docking.MapViewerToolView"
             x:CompileBindings="False"
             x:DataType="vm:MapViewerToolViewModel">
    <UserControl.Styles>
        <!-- Loading spinner for the panel overlay (#6). -->
        <Style Selector="PathIcon.mapSpinner">
            <Setter Property="RenderTransform"><RotateTransform /></Setter>
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,3">
          <DockPanel>
            <!-- Window controls, pinned to the right (#7). -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                <Button Click="OnFullScreen" Width="26" Height="22" Padding="0"
                        Background="Transparent" BorderThickness="0" ToolTip.Tip="{l:Loc MapV_FullScreenTip}">
                    <PathIcon Data="{DynamicResource Icon.FullScreen}" Width="14" Height="14" />
                </Button>
                <Button Click="OnFloatOtherScreen" Width="26" Height="22" Padding="0"
                        Background="Transparent" BorderThickness="0" ToolTip.Tip="{l:Loc MapV_FloatScreenTip}">
                    <PathIcon Data="{DynamicResource Icon.External}" Width="14" Height="14" />
                </Button>
                <Button Click="OnMoveToCenter" Width="26" Height="22" Padding="0"
                        Background="Transparent" BorderThickness="0" ToolTip.Tip="{l:Loc MapV_MoveCenterTip}">
                    <PathIcon Data="{DynamicResource Icon.Layout}" Width="14" Height="14" />
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="{l:Loc Common_OpenEllipsis}" Click="OnOpen" FontSize="11" Padding="8,2" />
                <Button Content="{l:Loc Common_OpenExternally}" Command="{Binding Map.OpenExternallyCommand}"
                        IsEnabled="{Binding Map.HasFile}" FontSize="11" Padding="8,2" />
                <!-- Compatible map outputs declared by the active thconfig's export-map commands (#2). -->
                <ComboBox MinWidth="130" MaxWidth="240" FontSize="11" VerticalAlignment="Center"
                          IsVisible="{Binding Map.HasAvailableOutputs}"
                          ItemsSource="{Binding Map.AvailableOutputs}"
                          SelectedItem="{Binding Map.SelectedOutput, Mode=TwoWay}"
                          ToolTip.Tip="{l:Loc MapV_OutputsTip}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Separator Width="1" Margin="3,2" Background="Gray" />
                <Button Content="◀" Command="{Binding Map.PrevPageCommand}"
                        IsVisible="{Binding Map.HasMultiplePages}" FontSize="11" Padding="6,2" />
                <TextBlock Text="{Binding Map.PageLabel}" VerticalAlignment="Center" FontSize="11"
                           IsVisible="{Binding Map.HasMultiplePages}" />
                <Button Content="▶" Command="{Binding Map.NextPageCommand}"
                        IsVisible="{Binding Map.HasMultiplePages}" FontSize="11" Padding="6,2" />
                <Separator Width="1" Margin="3,2" Background="Gray" />
                <Button Content="–" Command="{Binding Map.ZoomOutCommand}" FontSize="11" Padding="8,2" />
                <Button Content="{l:Loc MapV_Fit100}" Command="{Binding Map.ZoomResetCommand}" FontSize="11" Padding="6,2" />
                <Button Content="+" Command="{Binding Map.ZoomInCommand}" FontSize="11" Padding="8,2" />
                <Button Content="{l:Loc MapV_FitWindow}" ToolTip.Tip="{l:Loc MapV_FitWindowTip}"
                        Click="OnFit" IsEnabled="{Binding Map.HasImage}" FontSize="11" Padding="6,2" />
                <Button Content="{l:Loc Common_RefreshGlyph}" Command="{Binding Map.RefreshCommand}" FontSize="11" Padding="6,2" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Footer / info bar: file name + pages (Status) on the left; zoom %, size, mtime on the right (#8). -->
        <Border DockPanel.Dock="Bottom" Padding="6,2">
            <Border.Styles>
                <Style Selector="Border.mapSep">
                    <Setter Property="Width" Value="1" />
                    <Setter Property="Margin" Value="8,1" />
                    <Setter Property="Background" Value="#80808080" />
                </Style>
            </Border.Styles>
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Map.Status}" Foreground="Gray"
                           FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Map.ZoomPercent}" Foreground="Gray" FontSize="11"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding Map.HasFile}">
                        <Border Classes="mapSep" />
                        <TextBlock Text="{Binding Map.FileSizeDisplay}" Foreground="Gray" FontSize="11"
                                   VerticalAlignment="Center" />
                        <Border Classes="mapSep" />
                        <TextBlock Text="{Binding Map.ModifiedDisplay}" Foreground="Gray" FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <ScrollViewer x:Name="Scroll" Background="#15808080"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          PointerWheelChanged="OnWheel">
                <LayoutTransformControl HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12">
                    <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding Map.Zoom}" ScaleY="{Binding Map.Zoom}" />
                    </LayoutTransformControl.LayoutTransform>
                    <Image Source="{Binding Map.Image}" Stretch="None" />
                </LayoutTransformControl>
            </ScrollViewer>

            <!-- Off-thread render spinner overlay (#6). -->
            <Border IsVisible="{Binding Map.IsLoading}" Background="#33000000" IsHitTestVisible="False">
                <PathIcon Classes="mapSpinner" Data="{DynamicResource Icon.Loading}"
                          Width="40" Height="40" Foreground="#DDFFFFFF"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          RenderTransformOrigin="50%,50%" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
