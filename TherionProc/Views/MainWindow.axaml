<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TherionProc.ViewModels"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="800"
        x:Class="TherionProc.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1300" Height="800"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Window.KeyBindings populated at runtime via IKeyboardShortcutService (Decision #29). -->

    <Window.Styles>
        <!-- Medium icon buttons for the toolbar. -->
        <Style Selector="Button.tool">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{Binding MenuFile}">
                <MenuItem Header="{Binding MenuFileOpenFile}"   Command="{Binding OpenFileCommand}" />
                <MenuItem Header="{Binding MenuFileOpenFolder}" Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="_Preferences..." Click="OnPreferencesClick" />
                <Separator />
                <MenuItem Header="{Binding MenuFileExit}" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{Binding MenuView}">
                <MenuItem Header="{Binding MenuViewLanguage}">
                    <MenuItem Header="{Binding MenuViewLanguageEn}" Command="{Binding SwitchToEnglishCommand}" />
                    <MenuItem Header="{Binding MenuViewLanguageRo}" Command="{Binding SwitchToRomanianCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Workspace" Command="{Binding ToggleWorkspaceExplorerCommand}" />
                <MenuItem Header="Diagnostics" Command="{Binding ToggleDiagnosticsCommand}" />
                <Separator />
                <MenuItem Header="Strict parser mode"
                          ToggleType="CheckBox"
                          IsChecked="{Binding StrictParserMode, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="{Binding MenuBuild}">
                <MenuItem Header="_Build      F5"        Command="{Binding Build.BuildCommand}" />
                <MenuItem Header="_Rebuild    Ctrl+F5"   Command="{Binding Build.RebuildCommand}" />
                <MenuItem Header="_Cancel     Shift+F5"  Command="{Binding Build.CancelCommand}" />
                <Separator />
                <MenuItem Header="Open in _Loch   F9"    Command="{Binding Build.OpenInLochCommand}" />
                <MenuItem Header="Open in _Aven   F10"   Command="{Binding Build.OpenInAvenCommand}" />
                <Separator />
                <MenuItem Header="Open last _output folder" Command="{Binding Build.OpenLastOutputFolderCommand}" />
            </MenuItem>
        </Menu>

        <!-- Icon toolbar: navigation history, build/cancel, 3D viewers, full screen. -->
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,3">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button Classes="tool" Content="&#x2190;" Command="{Binding GoBackCommand}"
                        ToolTip.Tip="Back (Alt+Left)" />
                <Button Classes="tool" Content="&#x2192;" Command="{Binding GoForwardCommand}"
                        ToolTip.Tip="Forward (Alt+Right)" />
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <Button Classes="tool" Content="&#x25B6;" Foreground="#2E7D32"
                        Command="{Binding Build.BuildCommand}" ToolTip.Tip="Build (F5)" />
                <Button Classes="tool" Content="&#x25A0;" Foreground="#C62828"
                        Command="{Binding Build.CancelCommand}" ToolTip.Tip="Cancel build (Shift+F5)" />
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <Button Classes="tool" Content="&#x25F0;" Command="{Binding Build.OpenInLochCommand}"
                        IsEnabled="{Binding Build.HasLoxArtifact}" ToolTip.Tip="Open in Loch (F9)" />
                <Button Classes="tool" Content="&#x25F3;" Command="{Binding Build.OpenInAvenCommand}"
                        IsEnabled="{Binding Build.HasAvenArtifact}" ToolTip.Tip="Open in Aven (F10)" />
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <Button Classes="tool" Content="&#x26F6;" Click="OnToggleFullScreen"
                        ToolTip.Tip="Full screen (F11)" />
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                           Text="{Binding Build.Status}" Foreground="Gray" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="6,2">
            <TextBlock Text="{Binding StatusText}" Foreground="Gray" />
        </Border>

        <!-- VS-style docking host: documents (center) + dockable/floatable tool windows. -->
        <dock:DockControl x:Name="Dock" Layout="{Binding Layout}" Factory="{Binding Factory}" />
    </DockPanel>
</Window>
