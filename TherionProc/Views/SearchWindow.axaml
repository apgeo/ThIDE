<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TherionProc.ViewModels"
        xmlns:ae="using:AvaloniaEdit"
        x:Class="TherionProc.Views.SearchWindow"
        x:DataType="vm:SearchViewModel"
        Width="600" Height="640"
        WindowStartupLocation="CenterOwner"
        Title="Find in Files">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Spacing="6">
            <!-- Editable query with a persistent MRU dropdown of past 50 searches (#10). -->
            <AutoCompleteBox x:Name="QueryBox" Watermark="Search…"
                             Text="{Binding Query, Mode=TwoWay}"
                             ItemsSource="{Binding RecentQueries}"
                             FilterMode="ContainsOrdinal" MinimumPrefixLength="0" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <CheckBox Content="Match case"  IsChecked="{Binding MatchCase, Mode=TwoWay}" />
                <CheckBox Content="Whole word"  IsChecked="{Binding WholeWord, Mode=TwoWay}" />
                <CheckBox Content="Regex"       IsChecked="{Binding UseRegex, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Look in:" VerticalAlignment="Center" />
                <ComboBox MinWidth="120" ItemsSource="{Binding Scopes}"
                          SelectedItem="{Binding Scope, Mode=TwoWay}" />
                <Button Content="Find All" Command="{Binding SearchCommand}" IsDefault="True" />
            </StackPanel>

            <Grid ColumnDefinitions="Auto,*,Auto,160" RowDefinitions="Auto"
                  IsVisible="{Binding IsDirectoryScope}">
                <TextBlock Grid.Column="0" Text="Directory:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox  Grid.Column="1" Text="{Binding Directory, Mode=TwoWay}" />
                <TextBlock Grid.Column="2" Text="Mask:" VerticalAlignment="Center" Margin="8,0,8,0" />
                <TextBox  Grid.Column="3" Text="{Binding FileMask, Mode=TwoWay}" />
            </Grid>

            <TextBlock Foreground="Gray" Text="{Binding Status}" />
        </StackPanel>

        <Grid RowDefinitions="*,4,220" Margin="0,8,0,0">
            <ListBox x:Name="ResultsList" Grid.Row="0"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                     SelectionChanged="OnResultSelected"
                     DoubleTapped="OnResultActivated">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchHit">
                        <TextBlock Text="{Binding Display}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows" Background="Gray" />

            <!-- Inline peek of the selected result (single-click); double-click navigates (#5). -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1">
                <ae:TextEditor x:Name="Peek" IsReadOnly="True" ShowLineNumbers="True"
                               FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
