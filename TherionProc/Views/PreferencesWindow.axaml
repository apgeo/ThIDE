<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:TherionProc.Converters"
        xmlns:l="using:TherionProc.Resources"
        x:Class="TherionProc.Views.PreferencesWindow"
        x:CompileBindings="False"
        Title="{l:Loc Pref_Title}"
        Width="1080" Height="780"
        MinWidth="640" MinHeight="460"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- Footer: OK / Cancel -->
        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="{l:Loc Common_Cancel}" Click="OnCancel" MinWidth="80" />
                <Button Content="{l:Loc Common_Ok}" Click="OnOk" IsDefault="True" MinWidth="80" />
            </StackPanel>
        </Border>

        <!-- Left rail: search box + section list (VS2026-style options navigation). -->
        <Border DockPanel.Dock="Left" Width="200"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="8">
                <TextBox DockPanel.Dock="Top" Watermark="{l:Loc Pref_SearchWm}" Margin="0,0,0,8"
                         Text="{Binding SearchQuery, Mode=TwoWay}" />
                <ListBox ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Padding="2" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right pane: the selected section's settings. -->
        <ScrollViewer Padding="18" VerticalScrollBarVisibility="Auto">
            <Panel>
                <!-- General -->
                <StackPanel Spacing="10" IsVisible="{Binding IsGeneral}">
                    <TextBlock Text="{l:Loc Pref_General}" FontSize="16" FontWeight="Bold" />
                    <CheckBox Content="{l:Loc Pref_ReopenSession}"
                              IsChecked="{Binding RestoreSessionOnStartup}" />
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                        <TextBlock Text="{l:Loc Pref_Language}" VerticalAlignment="Center" Width="100" />
                        <ComboBox MinWidth="180" SelectedIndex="{Binding LanguageIndex, Mode=TwoWay}">
                            <ComboBoxItem>English</ComboBoxItem>
                            <ComboBoxItem>Română</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="{l:Loc Pref_LanguageHelp}"
                               Foreground="Gray" FontSize="11" />
                    <Separator Margin="0,6" />
                    <!-- QOL-09: configurable auto-save. -->
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                        <TextBlock Text="{l:Loc Pref_AutoSave}" VerticalAlignment="Center" Width="100" />
                        <ComboBox MinWidth="180" SelectedIndex="{Binding AutoSaveModeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{l:Loc Pref_AutoSaveOff}" />
                            <ComboBoxItem Content="{l:Loc Pref_AutoSaveDelay}" />
                            <ComboBoxItem Content="{l:Loc Pref_AutoSaveFocus}" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{l:Loc Pref_DelaySeconds}" VerticalAlignment="Center" Width="100" />
                        <NumericUpDown Minimum="5" Maximum="3600" Increment="5" MinWidth="120"
                                       Value="{Binding AutoSaveDelaySeconds, Mode=TwoWay}" />
                    </StackPanel>
                    <TextBlock Text="{l:Loc Pref_AutoSaveHelp}"
                               Foreground="Gray" FontSize="11" />
                    <Separator Margin="0,6" />
                    <!-- REL-05: opt-in, local-only telemetry / crash reports. -->
                    <CheckBox Content="{l:Loc Pref_Telemetry}"
                              IsChecked="{Binding TelemetryEnabled}" />
                    <TextBlock Text="{l:Loc Pref_TelemetryHelp}"
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Theme & Colors (#2) -->
                <StackPanel Spacing="10" IsVisible="{Binding IsTheme}">
                    <TextBlock Text="{l:Loc Pref_Theme}" FontSize="16" FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{l:Loc Pref_AppTheme}" VerticalAlignment="Center" Width="120" />
                        <ComboBox MinWidth="200" SelectedIndex="{Binding ThemeModeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{l:Loc Pref_ThemeSystem}" />
                            <ComboBoxItem Content="{l:Loc Pref_ThemeLight}" />
                            <ComboBoxItem Content="{l:Loc Pref_ThemeDark}" />
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="{l:Loc Pref_ThemeHelp}"
                               Foreground="Gray" FontSize="11" />

                    <Separator Margin="0,6" />
                    <CheckBox Content="{l:Loc Pref_CustomColors}"
                              IsChecked="{Binding UseCustomSyntaxColors}" />
                    <TextBlock Text="{l:Loc Pref_CustomColorsHelp}"
                               Foreground="Gray" FontSize="11" />
                    <Grid ColumnDefinitions="120,150,28" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          IsEnabled="{Binding UseCustomSyntaxColors}">
                        <Grid.Styles>
                            <Style Selector="TextBlock.lbl"><Setter Property="VerticalAlignment" Value="Center" /><Setter Property="Margin" Value="0,0,0,6" /></Style>
                            <Style Selector="TextBox.hex"><Setter Property="Margin" Value="0,0,8,6" /></Style>
                            <Style Selector="Border.swatch"><Setter Property="Width" Value="22" /><Setter Property="Height" Value="22" /><Setter Property="Margin" Value="0,0,0,6" /><Setter Property="BorderBrush" Value="Gray" /><Setter Property="BorderThickness" Value="1" /><Setter Property="CornerRadius" Value="3" /></Style>
                        </Grid.Styles>
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynKeyword}" />
                        <TextBox    Grid.Row="0" Grid.Column="1" Classes="hex" Text="{Binding SyntaxKeywordColor}" />
                        <Border     Grid.Row="0" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxKeywordColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynIdentifier}" />
                        <TextBox    Grid.Row="1" Grid.Column="1" Classes="hex" Text="{Binding SyntaxIdentifierColor}" />
                        <Border     Grid.Row="1" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxIdentifierColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynNumber}" />
                        <TextBox    Grid.Row="2" Grid.Column="1" Classes="hex" Text="{Binding SyntaxNumberColor}" />
                        <Border     Grid.Row="2" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxNumberColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynString}" />
                        <TextBox    Grid.Row="3" Grid.Column="1" Classes="hex" Text="{Binding SyntaxStringColor}" />
                        <Border     Grid.Row="3" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxStringColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynComment}" />
                        <TextBox    Grid.Row="4" Grid.Column="1" Classes="hex" Text="{Binding SyntaxCommentColor}" />
                        <Border     Grid.Row="4" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxCommentColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynOption}" />
                        <TextBox    Grid.Row="5" Grid.Column="1" Classes="hex" Text="{Binding SyntaxOptionColor}" />
                        <Border     Grid.Row="5" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxOptionColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Classes="lbl" Text="{l:Loc Pref_SynPunctuation}" />
                        <TextBox    Grid.Row="6" Grid.Column="1" Classes="hex" Text="{Binding SyntaxPunctuationColor}" />
                        <Border     Grid.Row="6" Grid.Column="2" Classes="swatch" Background="{Binding SyntaxPunctuationColor, Converter={x:Static conv:HexColorToBrushConverter.Instance}}" />
                    </Grid>
                </StackPanel>

                <!-- Editor -->
                <StackPanel Spacing="10" IsVisible="{Binding IsEditor}">
                    <TextBlock Text="{l:Loc Pref_Editor}" FontSize="16" FontWeight="Bold" />
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Pref_FontSize}"
                                   VerticalAlignment="Center" Margin="0,0,8,6" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="8" Maximum="32" Increment="1"
                                       Value="{Binding EditorFontSize}" Margin="0,0,0,6" MaxWidth="160"
                                       HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Pref_IndentSize}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="8" Increment="1"
                                       Value="{Binding IndentationSize}" MaxWidth="160" HorizontalAlignment="Left" />
                    </Grid>
                    <CheckBox Content="{l:Loc Pref_ShowLineNumbers}" IsChecked="{Binding ShowLineNumbers}" />
                    <CheckBox Content="{l:Loc Pref_HighlightCurrentLine}" IsChecked="{Binding HighlightCurrentLine}" />
                    <CheckBox Content="{l:Loc Pref_ConvertTabs}" IsChecked="{Binding ConvertTabsToSpaces}" />
                    <CheckBox Content="{l:Loc Pref_RenamePreview}"
                              IsChecked="{Binding ShowRenamePreviewBeforeApply}" />
                    <CheckBox Content="{l:Loc Pref_FormatOnSave}"
                              IsChecked="{Binding FormatOnSave}" />
                </StackPanel>

                <!-- Editor Features (Section B / EDIT-*) -->
                <StackPanel Spacing="8" IsVisible="{Binding IsEditorFeatures}">
                    <TextBlock Text="{l:Loc Pref_EditorFeatures}" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{l:Loc Pref_EditorFeaturesHelp}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <!-- The feature list can be longer than the window; give it its own scroll so
                         every row stays reachable (#3). MaxHeight tracks the window height. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="{Binding $parent[Window].Bounds.Height, Converter={x:Static conv:RatioConverter.Instance}, ConverterParameter=0.70}">
                    <ItemsControl ItemsSource="{Binding EditorFeatureRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,6" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                        <CheckBox Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                                  VerticalAlignment="Top" Margin="0,2,8,0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsCompiledIn}" />
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                                                    CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Code}" FontSize="10" Foreground="Gray" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}"
                                                   Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Performance / large-file guards (#10) -->
                <StackPanel Spacing="10" IsVisible="{Binding IsPerformance}">
                    <TextBlock Text="{l:Loc Pref_Performance}" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{l:Loc Pref_PerfHelp1}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Pref_MaxHighlightLines}"
                                   VerticalAlignment="Center" Margin="0,0,8,6" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="1000" Maximum="2000000" Increment="1000"
                                       Value="{Binding MaxHighlightLines}" Margin="0,0,0,6" MaxWidth="180"
                                       HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Pref_MaxHighlightKB}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="64" Maximum="1048576" Increment="128"
                                       Value="{Binding MaxHighlightKB}" MaxWidth="180" HorizontalAlignment="Left" />
                    </Grid>
                    <TextBlock Text="{l:Loc Pref_PerfHelp2}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Pref_MaxParseLines}"
                                   VerticalAlignment="Center" Margin="0,0,8,6" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="1000" Maximum="2000000" Increment="1000"
                                       Value="{Binding MaxParseLines}" Margin="0,0,0,6" MaxWidth="180"
                                       HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Pref_MaxParseKB}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="64" Maximum="1048576" Increment="128"
                                       Value="{Binding MaxParseKB}" MaxWidth="180" HorizontalAlignment="Left" />
                    </Grid>
                    <TextBlock Text="{l:Loc Pref_PerfHelp3}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Pref_MaxStations}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="100" Maximum="1000000" Increment="500"
                                       Value="{Binding StationSearchLimit}" MaxWidth="180" HorizontalAlignment="Left" />
                    </Grid>
                    <TextBlock Text="{l:Loc Pref_PerfHelp4}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Pref_StartupTimeout}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="600" Increment="5"
                                       Value="{Binding StartupLoadTimeoutSeconds}" MaxWidth="180" HorizontalAlignment="Left" />
                    </Grid>
                </StackPanel>

                <!-- Workspace -->
                <StackPanel Spacing="10" IsVisible="{Binding IsWorkspace}">
                    <TextBlock Text="{l:Loc Pref_Workspace}" FontSize="16" FontWeight="Bold" />
                    <CheckBox Content="{l:Loc Pref_ReloadExternal}"
                              IsChecked="{Binding AutoReloadExternalChanges}" />
                    <CheckBox Content="{l:Loc Pref_UpdateGraph}"
                              IsChecked="{Binding AutoReloadGraphOnExternalChange}" />
                    <Separator Margin="0,6" />
                    <CheckBox Content="{l:Loc Pref_QuickOpenScope}"
                              IsChecked="{Binding QuickOpenThconfigScope}" />
                    <TextBlock Text="{l:Loc Pref_QuickOpenHelp}"
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Build & Output -->
                <StackPanel Spacing="10" IsVisible="{Binding IsBuild}">
                    <TextBlock Text="{l:Loc Pref_Build}" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{l:Loc Pref_AfterBuildOpen}" FontWeight="SemiBold" />
                    <CheckBox Content="{l:Loc Pref_OpenLox}" IsChecked="{Binding OpenLoxAfterBuild}" />
                    <CheckBox Content="{l:Loc Pref_Open3d}" IsChecked="{Binding Open3dAfterBuild}" />
                    <CheckBox Content="{l:Loc Pref_OpenPdf}" IsChecked="{Binding OpenPdfAfterBuild}" />
                    <TextBlock Text="{l:Loc Pref_OpenNoneHelp}" Foreground="Gray" FontSize="11" />
                    <CheckBox Content="{l:Loc Pref_OpenAll}"
                              IsChecked="{Binding OpenAllOutputsAfterBuild}" />
                    <Separator Margin="0,6" />
                    <!-- BUILD-07: compile-on-save (off by default). -->
                    <CheckBox Content="{l:Loc Pref_CompileOnSave}"
                              IsChecked="{Binding CompileOnSave}" />
                    <TextBlock Text="{l:Loc Pref_CompileOnSaveHelp}"
                               Foreground="Gray" FontSize="11" />
                    <Separator Margin="0,6" />
                    <CheckBox Content="{l:Loc Pref_EnsureDirs}"
                              IsChecked="{Binding EnsureOutputDirectories}" />
                    <TextBlock Text="{l:Loc Pref_EnsureDirsHelp}"
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Visualization (VIS-*): per-feature enable/disable. -->
                <StackPanel Spacing="10" IsVisible="{Binding IsVisualization}">
                    <TextBlock Text="{l:Loc Pref_Visualization}" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{l:Loc Pref_VisualizationHelp}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <CheckBox Content="{l:Loc Pref_Vis_LivePreview}"
                              IsChecked="{Binding EnableLivePreview}" />
                    <CheckBox Content="{l:Loc Pref_Vis_MapViewer}"
                              IsChecked="{Binding EnableInAppViewer}" />
                    <CheckBox Content="{l:Loc Pref_Vis_MapAuto}"
                              IsChecked="{Binding EnableMapAutoPreview}" />
                    <CheckBox Content="{l:Loc Pref_Vis_Model3D}"
                              IsChecked="{Binding EnableModel3DViewer}" />
                    <CheckBox Content="{l:Loc Pref_Vis_Model3DAuto}"
                              IsChecked="{Binding EnableModel3DAutoPreview}" />
                    <CheckBox Content="{l:Loc Pref_Vis_Structural}"
                              IsChecked="{Binding EnableStructuralGeology}" />

                    <TextBlock Text="{l:Loc Pref_SurveyAnalytics}" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock Text="{l:Loc Pref_SurveyAnalyticsHelp}"
                               Foreground="Gray" TextWrapping="Wrap" />
                    <CheckBox Content="{l:Loc Pref_Analytics_Project}"
                              IsChecked="{Binding EnableProjectAnalytics}" />
                    <CheckBox Content="{l:Loc Pref_Analytics_ObjectBrowser}"
                              IsChecked="{Binding EnableObjectBrowserEntities}" />
                    <CheckBox Content="{l:Loc Pref_Analytics_Todo}"
                              IsChecked="{Binding EnableTodoScan}" />
                    <CheckBox Content="{l:Loc Pref_Analytics_Media}"
                              IsChecked="{Binding EnableMediaScan}" />
                </StackPanel>

                <!-- External Tools (moved here from the dockable Settings panel, #13) -->
                <DockPanel IsVisible="{Binding IsExternal}" VerticalAlignment="Top">
                    <TextBlock DockPanel.Dock="Top" Text="{l:Loc Pref_External}"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                        <Button Content="{l:Loc Common_Refresh}" Command="{Binding ExternalTools.RefreshCommand}" />
                        <TextBlock VerticalAlignment="Center" Foreground="Gray"
                                   Text="{Binding ExternalTools.Status}" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding ExternalTools.Tools}"
                              x:CompileBindings="False" Height="440" VerticalAlignment="Top"
                              GridLinesVisibility="Horizontal"
                              CanUserResizeColumns="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Tool}"     Binding="{Binding ToolId}"  Width="Auto" MinWidth="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Detected}" Binding="{Binding Path}"    Width="*"   MinWidth="160" IsReadOnly="True" />
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Version}"  Binding="{Binding Version}" Width="Auto" MinWidth="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Source}"   Binding="{Binding Source}"  Width="Auto" MinWidth="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Override}" Binding="{Binding OverridePath, Mode=TwoWay}" Width="Auto" MinWidth="160" />
                            <DataGridTemplateColumn Header="" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{l:Loc Common_Test}" Command="{Binding TestCommand}" Margin="2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Result}"   Binding="{Binding TestResult}" Width="110" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- Extensions (EXT-03 hooks, EXT-04 plugins) -->
                <StackPanel Spacing="10" IsVisible="{Binding IsExtensions}">
                    <TextBlock Text="{l:Loc Pref_Extensions}" FontSize="16" FontWeight="Bold" />

                    <!-- EXT-03: scripting / macro hooks. -->
                    <CheckBox Content="{l:Loc Pref_ScriptHooks}"
                              IsChecked="{Binding EnableScriptHooks}" />
                    <TextBlock Text="{l:Loc Pref_ScriptHooksHelp}"
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0"
                          IsEnabled="{Binding EnableScriptHooks}">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Pref_OnOpen}" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding HookOnOpen}" Watermark="{l:Loc Pref_CommandWm}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Pref_OnSave}" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding HookOnSave}" Watermark="{l:Loc Pref_CommandWm}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:Loc Pref_OnBuild}" VerticalAlignment="Center" />
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding HookOnBuild}" Watermark="{l:Loc Pref_CommandWm}" />
                    </Grid>

                    <Separator Margin="0,6" />
                    <!-- EXT-04: plugin assemblies. -->
                    <CheckBox Content="{l:Loc Pref_LoadPlugins}"
                              IsChecked="{Binding EnablePlugins}" />
                    <TextBlock Text="{l:Loc Pref_LoadPluginsHelp}"
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />

                    <Separator Margin="0,6" />
                    <TextBlock Text="{l:Loc Pref_CliHelp}"
                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Keyboard Shortcuts -->
                <DockPanel IsVisible="{Binding IsKeyboard}" VerticalAlignment="Top">
                    <TextBlock DockPanel.Dock="Top" Text="{l:Loc Pref_Keyboard}"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                        <Button Content="{l:Loc Pref_ResetAll}" Command="{Binding Keyboard.ResetAllCommand}" />
                        <TextBlock VerticalAlignment="Center" Foreground="Gray" FontSize="11"
                                   Text="{l:Loc Pref_KbHelp}" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Keyboard.Rows}"
                              x:CompileBindings="False" VerticalAlignment="Top"
                              GridLinesVisibility="Horizontal" Height="440"
                              CanUserResizeColumns="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Command}" Binding="{Binding CommandId}" Width="Auto" MinWidth="120" MaxWidth="260" IsReadOnly="True" />
                            <!-- Capture box: focus it and press a chord to record the gesture (#11). -->
                            <DataGridTemplateColumn Header="{l:Loc Pref_Col_Gesture}" Width="*" MinWidth="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Gesture}" IsReadOnly="True"
                                                 Watermark="{l:Loc Pref_PressKeysWm}" Margin="2"
                                                 KeyDown="OnGestureKeyDown"
                                                 ToolTip.Tip="{l:Loc Pref_GestureTip}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{l:Loc Pref_Col_Default}" Binding="{Binding DefaultGesture}" Width="Auto" MinWidth="90" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{l:Loc Pref_Reset}" Command="{Binding ResetToDefaultCommand}" Margin="2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Panel>
        </ScrollViewer>
    </DockPanel>
</Window>
