## .NET / Visual Studio .gitignore
## Based on the official GitHub VisualStudio template, trimmed and tailored for TherionProc.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace.bak

# Rider / JetBrains
.idea/
*.sln.iml
*.DotSettings.user

# MSTest / NUnit / xUnit test results and coverage
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# .NET / Build engine
project.lock.json
project.fragment.lock.json
artifacts/
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual C++ / cache
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Profiler
*.psess
*.vsp
*.vspx
*.sap

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
.nuget/

# MSBuild Binary and Structured Log
*.binlog

# Publish / deployment
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/

# Others
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs
node_modules/
*.[Cc]ache
!?*.[Cc]ache/
ClientBin/
~$*
*~
*.dbml
*.bak

# Backup & report files from converting an old project file
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# Telerik's JustMock configuration
*.jmconfig

# BizTalk / others
*.btp.cs
*.btm.cs
*.odx.cs
*.xsd.cs

# OS-generated files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Claude Code local (machine-specific) settings — keep shared .claude/ config tracked
.claude/*

tests/Corpus/sample_projects/*
# Local-only quarantined corpus (downloaded, never committed)
tests/Corpus_quarantine/

# Local-only corpus tooling (not committed)
/corpus-tools/
