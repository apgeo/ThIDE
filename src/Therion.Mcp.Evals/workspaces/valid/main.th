survey cave

  survey upper
    centreline
      data normal from to length compass clino
      0 1 5.0 90 0
      1 2 4.0 45 -10
    endcentreline
  endsurvey

  survey lower
    centreline
      data normal from to length compass clino
      0 1 6.0 180 5
    endcentreline
  endsurvey

  equate 2@upper 0@lower

endsurvey
