<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThIDE.ViewModels"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:l="using:ThIDE.Resources"
        x:Class="ThIDE.Views.ReplaceWindow"
        x:DataType="vm:ReplaceInFilesViewModel"
        Width="1240" Height="680"
        WindowStartupLocation="CenterOwner"
        Title="{l:Loc Replace_Title}">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Spacing="6">
            <TextBox x:Name="QueryBox" Watermark="{l:Loc Replace_FindWm}" Text="{Binding Query, Mode=TwoWay}" />
            <TextBox Watermark="{l:Loc Replace_WithWm}" Text="{Binding Replacement, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <CheckBox Content="{l:Loc Search_MatchCase}"  IsChecked="{Binding MatchCase, Mode=TwoWay}" />
                <CheckBox Content="{l:Loc Search_WholeWord}"  IsChecked="{Binding WholeWord, Mode=TwoWay}" />
                <CheckBox Content="{l:Loc Search_Regex}"       IsChecked="{Binding UseRegex, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{l:Loc Search_LookIn}" VerticalAlignment="Center" />
                <ComboBox MinWidth="180" ItemsSource="{Binding Scopes}"
                          SelectedItem="{Binding Scope, Mode=TwoWay}" />
                <Button Content="{l:Loc Search_FindAll}" Command="{Binding FindAllCommand}" />
                <Button Content="{l:Loc Replace_ReplaceAll}" Command="{Binding ReplaceAllCommand}" IsDefault="True"
                        Background="#C62828" Foreground="White" />
                <!-- Global (cross-file) undo/redo of the whole Replace-All operation. -->
                <Button Content="{l:Loc Common_Undo}" Command="{Binding UndoCommand}" ToolTip.Tip="{l:Loc Replace_UndoTip}" />
                <Button Content="{l:Loc Common_Redo}" Command="{Binding RedoCommand}" ToolTip.Tip="{l:Loc Replace_RedoTip}" />
            </StackPanel>

            <Grid ColumnDefinitions="Auto,*,Auto,160" RowDefinitions="Auto"
                  IsVisible="{Binding IsDirectoryScope}">
                <TextBlock Grid.Column="0" Text="{l:Loc Search_Directory}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox  Grid.Column="1" Text="{Binding Directory, Mode=TwoWay}" />
                <TextBlock Grid.Column="2" Text="{l:Loc Search_Mask}" VerticalAlignment="Center" Margin="8,0,8,0" />
                <TextBox  Grid.Column="3" Text="{Binding FileMask, Mode=TwoWay}" />
            </Grid>

            <TextBlock Foreground="Gray" Text="{Binding Status}" />
        </StackPanel>

        <Grid RowDefinitions="*,4,220" Margin="0,8,0,0">
            <ListBox x:Name="ResultsList" Grid.Row="0"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                     SelectionChanged="OnResultSelected"
                     DoubleTapped="OnResultActivated">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchHit">
                        <TextBlock Text="{Binding Display}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows" Background="Gray" />

            <!-- Inline peek of the selected match; double-click navigates. -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1">
                <ae:TextEditor x:Name="Peek" IsReadOnly="True" ShowLineNumbers="True"
                               FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
