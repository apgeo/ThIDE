<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThIDE.ViewModels"
             xmlns:views="using:ThIDE.Views"
             xmlns:l="using:ThIDE.Resources"
             x:Class="ThIDE.Views.RelationalMapView"
             x:DataType="vm:RelationalMapViewModel">

    <DockPanel>
        <!-- Toolbar: files toggle, refresh, legend, status. -->
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="8,5">
            <WrapPanel Orientation="Horizontal">
                <ToggleButton Margin="0,0,8,0" Padding="8,3"
                              IsChecked="{Binding IncludeFiles, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc RelMap_IncludeFilesTip}">
                    <TextBlock Text="{l:Loc RelMap_IncludeFiles}" VerticalAlignment="Center" />
                </ToggleButton>
                <Button Margin="0,0,8,0" Padding="8,3" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="{l:Loc RelMap_RefreshTip}">
                    <TextBlock Text="{l:Loc Common_RefreshGlyph}" VerticalAlignment="Center" />
                </Button>

                <ComboBox MinWidth="180" Margin="0,0,8,0" VerticalAlignment="Center"
                          ItemsSource="{Binding LayoutOptions}"
                          SelectedItem="{Binding SelectedLayout, Mode=TwoWay}"
                          ToolTip.Tip="{l:Loc RelMap_LayoutTip}" />

                <!-- Size-by-level + zoom controls (#2). -->
                <ToggleButton Margin="0,0,8,0" Padding="8,3" IsChecked="{Binding SizeByLevel, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc RelMap_SizeByLevelTip}">
                    <TextBlock Text="{l:Loc RelMap_SizeByLevel}" VerticalAlignment="Center" />
                </ToggleButton>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Button Padding="9,3" Command="{Binding ZoomOutCommand}" ToolTip.Tip="{l:Loc RelMap_ZoomOut}">−</Button>
                    <Button Padding="6,3" Margin="2,0" Command="{Binding ZoomResetCommand}" ToolTip.Tip="{l:Loc RelMap_ResetZoom}">100%</Button>
                    <Button Padding="9,3" Command="{Binding ZoomInCommand}" ToolTip.Tip="{l:Loc RelMap_ZoomIn}">+</Button>
                    <Button Padding="8,3" Margin="2,0" Click="OnFitClick" ToolTip.Tip="{l:Loc RelMap_FitTip}" Content="{l:Loc RelMap_Fit}" />
                </StackPanel>

                <!-- Legend. -->
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,12,0">
                    <StackPanel.Styles>
                        <Style Selector="Ellipse"><Setter Property="Width" Value="11"/><Setter Property="Height" Value="11"/></Style>
                        <Style Selector="StackPanel.lg"><Setter Property="Orientation" Value="Horizontal"/></Style>
                        <Style Selector="StackPanel.lg > TextBlock"><Setter Property="Margin" Value="3,0,0,0"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="FontSize" Value="11"/></Style>
                        <Style Selector="StackPanel.lg > Ellipse"><Setter Property="VerticalAlignment" Value="Center"/></Style>
                    </StackPanel.Styles>
                    <StackPanel Classes="lg"><Ellipse Fill="#1565C0"/><TextBlock Text="{l:Loc RelMap_Survey}"/></StackPanel>
                    <StackPanel Classes="lg"><Ellipse Fill="#00897B"/><TextBlock Text="{l:Loc RelMap_Map}"/></StackPanel>
                    <StackPanel Classes="lg"><Ellipse Fill="#AD1457"/><TextBlock Text="{l:Loc RelMap_Scrap}"/></StackPanel>
                    <StackPanel Classes="lg"><Ellipse Fill="#2E7D32"/><TextBlock Text="thconfig"/></StackPanel>
                    <StackPanel Classes="lg"><Ellipse Fill="#E65100"/><TextBlock Text=".th"/></StackPanel>
                    <StackPanel Classes="lg"><Ellipse Fill="#6A1B9A"/><TextBlock Text=".th2"/></StackPanel>
                </StackPanel>

                <TextBlock Text="{Binding Status}" Foreground="Gray" VerticalAlignment="Center" />
            </WrapPanel>
        </Border>

        <!-- Hint bar. -->
        <Border DockPanel.Dock="Bottom" Background="#11000000" Padding="8,3">
            <TextBlock Foreground="Gray" FontSize="11"
                       Text="{l:Loc RelMap_Hint}" />
        </Border>

        <ScrollViewer x:Name="DiagramScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
            <!-- LayoutTransformControl scales the diagram so the scrollbars track the zoomed size (#2). -->
            <LayoutTransformControl x:Name="ZoomHost">
                <LayoutTransformControl.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                </LayoutTransformControl.LayoutTransform>
                <Panel x:Name="DiagramRoot"
                       Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                    <views:RelationalEdgesControl x:Name="EdgeLayer" IsVisible="{Binding ShowEdges}" />

                    <ItemsControl x:Name="NodesHost" ItemsSource="{Binding Nodes}"
                                  x:CompileBindings="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl#NodesHost > ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding Width}" Height="{Binding Height}"
                                    Background="{Binding Fill}" BorderBrush="{Binding Stroke}"
                                    BorderThickness="1.5" CornerRadius="6" Padding="8,4"
                                    ToolTip.Tip="{Binding Label}">
                                <Grid RowDefinitions="Auto,Auto,*">
                                    <TextBlock Grid.Row="0" Text="{Binding KindLabel}"
                                               FontSize="9" Foreground="{Binding Stroke}" Opacity="0.85" />
                                    <TextBlock Grid.Row="1" Text="{Binding Label}"
                                               FontWeight="SemiBold" FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="2" Text="{Binding SubLabel}"
                                               IsVisible="{Binding HasSubLabel}"
                                               FontSize="10" Foreground="Gray"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Panel>
            </LayoutTransformControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
