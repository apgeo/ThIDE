<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:ThIDE.Views"
        xmlns:l="using:ThIDE.Resources"
        x:Class="ThIDE.Views.ReferencesWindow"
        Title="{l:Loc Refs_Title}"
        Width="760" Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
    <DockPanel>
        <TextBlock x:Name="Header" DockPanel.Dock="Top" Margin="10,8,10,4"
                   Foreground="Gray" FontSize="12" TextTrimming="CharacterEllipsis" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="8,6">
            <Button Content="{l:Loc Refs_GoTo}" Padding="10,3" Click="OnNavigateClick" />
            <Button Content="{l:Loc Common_Close}" Padding="10,3" Click="OnCloseClick" />
        </StackPanel>
        <DataGrid x:Name="Grid"
                  x:DataType="views:ReferenceRow"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Single"
                  AutoGenerateColumns="False"
                  DoubleTapped="OnDoubleTapped">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{l:Loc Common_File}" Binding="{Binding FileName}" Width="180" />
                <DataGridTextColumn Header="{l:Loc Browser_Col_Line}" Binding="{Binding Line}" Width="60" />
                <DataGridTextColumn Header="{l:Loc Refs_Col_Kind}" Binding="{Binding Kind}" Width="100" />
                <DataGridTextColumn Header="{l:Loc Refs_Col_Text}" Binding="{Binding Preview}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
