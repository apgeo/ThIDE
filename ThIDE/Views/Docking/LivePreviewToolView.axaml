<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThIDE.ViewModels.Docking"
             xmlns:views="using:ThIDE.Views"
             xmlns:conv="using:ThIDE.Converters"
             xmlns:l="using:ThIDE.Resources"
             x:Class="ThIDE.Views.Docking.LivePreviewToolView"
             x:CompileBindings="False"
             x:DataType="vm:LivePreviewToolViewModel">
    <UserControl.Resources>
        <conv:StringEqualsConverter x:Key="ColorEquals" />
        <conv:BoolAndConverter x:Key="BoolAnd" />
    </UserControl.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,3">
            <WrapPanel Orientation="Horizontal">
                <!-- View: plan, or a projected profile along a bearing (radio-style push buttons). -->
                <TextBlock Text="{l:Loc M3D_View}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="0,0,4,0" />
                <ToggleButton Content="{l:Loc M3D_Plan}" Command="{Binding Preview.SetViewModeCommand}" CommandParameter="plan"
                              IsChecked="{Binding Preview.ViewMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=plan}"
                              ToolTip.Tip="{l:Loc Live_PlanTip}" FontSize="11" Padding="8,2" Margin="0,0,6,2" />
                <!-- Projected profile: one button per cardinal bearing (the section extends along it). -->
                <ToggleButton Content="N" Command="{Binding Preview.SetViewModeCommand}" CommandParameter="north"
                              IsChecked="{Binding Preview.ViewMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=north}"
                              ToolTip.Tip="{l:Loc Live_ProfN}" FontSize="11" Padding="8,2" Margin="0,0,2,2" />
                <ToggleButton Content="E" Command="{Binding Preview.SetViewModeCommand}" CommandParameter="east"
                              IsChecked="{Binding Preview.ViewMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=east}"
                              ToolTip.Tip="{l:Loc Live_ProfE}" FontSize="11" Padding="8,2" Margin="0,0,2,2" />
                <ToggleButton Content="S" Command="{Binding Preview.SetViewModeCommand}" CommandParameter="south"
                              IsChecked="{Binding Preview.ViewMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=south}"
                              ToolTip.Tip="{l:Loc Live_ProfS}" FontSize="11" Padding="8,2" Margin="0,0,2,2" />
                <ToggleButton Content="W" Command="{Binding Preview.SetViewModeCommand}" CommandParameter="west"
                              IsChecked="{Binding Preview.ViewMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=west}"
                              ToolTip.Tip="{l:Loc Live_ProfW}" FontSize="11" Padding="8,2" Margin="0,0,2,2" />
                <ToggleButton Content="{l:Loc Live_Custom}" Command="{Binding Preview.SetViewModeCommand}" CommandParameter="custom"
                              IsChecked="{Binding Preview.ViewMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=custom}"
                              ToolTip.Tip="{l:Loc Live_CustomTip}" FontSize="11" Padding="8,2" Margin="0,0,4,2" />
                <!-- Custom-bearing slider (0–359°): live-updates the projection as it moves. -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,6,2"
                            IsVisible="{Binding Preview.IsCustomProfile}">
                    <Slider Width="130" Minimum="0" Maximum="359" VerticalAlignment="Center"
                            Value="{Binding Preview.CustomAzimuth, Mode=TwoWay}"
                            ToolTip.Tip="{l:Loc Live_BearingTip}" />
                    <TextBlock Text="{Binding Preview.CustomAzimuth, StringFormat='{}{0:0}°'}"
                               VerticalAlignment="Center" FontSize="11" Foreground="Gray" MinWidth="30" />
                </StackPanel>
                <Button Content="{l:Loc Common_RefreshGlyph}" Command="{Binding Preview.RefreshCommand}" FontSize="11" Padding="8,2" Margin="0,0,6,2" />

                <Separator Width="1" Margin="3,2" Background="Gray" />

                <!-- Splays: show + draw mode (faded lines vs edge points only). -->
                <ToggleButton Content="{l:Loc M3D_Splays}" IsChecked="{Binding Preview.ShowSplays, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_SplaysTip}" FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                <ToggleButton Content="{l:Loc Live_AsLines}" IsChecked="{Binding Preview.SplaysAsLines, Mode=TwoWay}"
                              IsEnabled="{Binding Preview.ShowSplays}"
                              ToolTip.Tip="{l:Loc Live_AsLinesTip}" FontSize="11" Padding="6,2" Margin="0,0,6,2" />

                <Separator Width="1" Margin="3,2" Background="Gray" />

                <!-- Debug overlays: station labels + provenance colouring. -->
                <ToggleButton Content="{l:Loc M3D_Labels}" IsChecked="{Binding Preview.ShowStationLabels, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_LabelsTip}" FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                <ToggleButton Content="survey.station" IsChecked="{Binding Preview.ShowSurveyNames, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_SurveyStationTip}" FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                <ToggleButton Content="{l:Loc Browser_Tab_Stations}" IsChecked="{Binding Preview.ShowStationSymbols, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_StationsTip}" FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                <ToggleButton Content="{l:Loc Live_Junctions}" IsChecked="{Binding Preview.ShowJunctions, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_JunctionsTip}"
                              FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                <ToggleButton Content="{l:Loc Live_Legend}" IsChecked="{Binding Preview.ShowLegend, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_LegendTip}"
                              FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                <ToggleButton Content="{l:Loc Live_Separate}" IsChecked="{Binding Preview.SeparateComponents, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc Live_SeparateTip}"
                              FontSize="11" Padding="6,2" Margin="0,0,6,2" />

                <Separator Width="1" Margin="3,2" Background="Gray" />

                <!-- Colour legs by data origin (also buckets the legend / visibility groups). -->
                <TextBlock Text="{l:Loc Live_Color}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="0,0,4,0" />
                <ToggleButton Content="{l:Loc Live_None}" Command="{Binding Preview.SetColorModeCommand}" CommandParameter="none" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                              IsChecked="{Binding Preview.ColorMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=none}" />
                <ToggleButton Content="{l:Loc Domain_Survey}" Command="{Binding Preview.SetColorModeCommand}" CommandParameter="survey" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                              ToolTip.Tip="{l:Loc Live_ColSurveyTip}"
                              IsChecked="{Binding Preview.ColorMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=survey}" />
                <ToggleButton Content="{l:Loc Common_File}" Command="{Binding Preview.SetColorModeCommand}" CommandParameter="file" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                              ToolTip.Tip="{l:Loc Live_ColFileTip}"
                              IsChecked="{Binding Preview.ColorMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=file}" />
                <ToggleButton Content="{l:Loc Live_Component}" Command="{Binding Preview.SetColorModeCommand}" CommandParameter="component" FontSize="11" Padding="6,2" Margin="0,0,6,2"
                              ToolTip.Tip="{l:Loc Live_ComponentTip}"
                              IsChecked="{Binding Preview.ColorMode, Mode=OneWay, Converter={StaticResource ColorEquals}, ConverterParameter=component}" />

                <TextBlock Text="{Binding Preview.Status}" Foreground="Gray" VerticalAlignment="Center"
                           FontSize="11" TextTrimming="CharacterEllipsis" />
            </WrapPanel>
        </Border>

        <Grid>
            <views:LivePreviewControl x:Name="Sketch" Segments="{Binding Preview.Segments}"
                                      AllSegments="{Binding Preview.FullSegments}"
                                      AllSplays="{Binding Preview.FullSplays}"
                                      Splays="{Binding Preview.Splays}"
                                      SplaysAsLines="{Binding Preview.SplaysAsLines}"
                                      StationPoints="{Binding Preview.StationPoints}"
                                      LeadMarkers="{Binding Preview.LeadMarkers}"
                                      EquateMarkers="{Binding Preview.EquateMarkers}"
                                      ShowJunctions="{Binding Preview.ShowJunctions}"
                                      ShowSplays="{Binding Preview.ShowSplays}"
                                      ShowStationSymbols="{Binding Preview.ShowStationSymbols}"
                                      ShowLabels="{Binding Preview.ShowStationLabels}"
                                      ShowSurveyNames="{Binding Preview.ShowSurveyNames}"
                                      ShowNorthArrow="{Binding Preview.IsPlan}"
                                      ColorMode="{Binding Preview.ColorMode}" />

            <!-- Drawing-area caption (top-right): "Plan view" / "Projected profile view (N/E/S/W)" /
                 "… (toward <az>°)". Click-through so it never blocks the sketch. -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                    Background="#E62B2B2B" CornerRadius="4" Padding="7,3" IsHitTestVisible="False"
                    BoxShadow="0 1 4 0 #40000000">
                <TextBlock Text="{Binding Preview.ViewLabel}" FontSize="11" FontWeight="SemiBold"
                           Foreground="#EEEEEE" />
            </Border>

            <!-- Interactive legend = the per-survey/file/component visibility list. Hover a row to
                 frame that group in the sketch. Shown only when enabled and there's >1 group. -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"
                    Background="#E62B2B2B" CornerRadius="4" Padding="6,5" BoxShadow="0 1 4 0 #40000000">
                <Border.IsVisible>
                    <MultiBinding Converter="{StaticResource BoolAnd}">
                        <Binding Path="Preview.ShowLegend" />
                        <Binding Path="Preview.HasGroups" />
                    </MultiBinding>
                </Border.IsVisible>
                <DockPanel MaxWidth="220">
                    <TextBlock DockPanel.Dock="Top" Text="{l:Loc Live_Groups}" FontWeight="SemiBold" FontSize="11"
                               Foreground="#EEEEEE" Margin="0,0,0,3" />
                    <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,4">
                        <Button Content="{l:Loc Live_All}" Command="{Binding Preview.ShowAllGroupsCommand}" FontSize="10" Padding="4,0" Margin="0,0,2,0"
                                ToolTip.Tip="{l:Loc Live_AllTip}" />
                        <Button Content="{l:Loc Live_NoneBtn}" Command="{Binding Preview.HideAllGroupsCommand}" FontSize="10" Padding="4,0" Margin="0,0,2,0"
                                ToolTip.Tip="{l:Loc Live_NoneTip}" />
                        <Button Content="{l:Loc Live_Invert}" Command="{Binding Preview.InvertGroupsCommand}" FontSize="10" Padding="4,0" Margin="0,0,2,0"
                                ToolTip.Tip="{l:Loc Live_InvertTip}" />
                        <Button Content="{l:Loc Live_Main}" Command="{Binding Preview.ShowOnlyMainCommand}" FontSize="10" Padding="4,0"
                                ToolTip.Tip="{l:Loc Live_MainTip}" />
                    </UniformGrid>
                    <ScrollViewer x:Name="GroupScroller" MaxHeight="260" HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Visible" AllowAutoHide="False">
                        <!-- Right margin reserves space so the always-on scrollbar never sits over the titles. -->
                        <ItemsControl x:Name="GroupList" ItemsSource="{Binding Preview.Groups}" Margin="0,0,14,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,1" Background="Transparent"
                                          ToolTip.Tip="{l:Loc Live_GroupRowTip}">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                  MinWidth="0" Padding="0" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Width="11" Height="11" CornerRadius="2"
                                                Background="{Binding Swatch}" Margin="0,0,5,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding Label}" FontSize="11" Foreground="#EEEEEE"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
