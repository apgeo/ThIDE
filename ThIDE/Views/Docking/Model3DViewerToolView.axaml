<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThIDE.ViewModels.Docking"
             xmlns:docking="using:ThIDE.Views.Docking"
             xmlns:cnv="using:Avalonia.Data.Converters"
             xmlns:conv="using:ThIDE.Converters"
             xmlns:l="using:ThIDE.Resources"
             x:Class="ThIDE.Views.Docking.Model3DViewerToolView"
             x:CompileBindings="False"
             x:DataType="vm:Model3DViewerToolViewModel">
    <UserControl.Resources>
        <conv:StringEqualsConverter x:Key="ShadingEquals" />
    </UserControl.Resources>
    <!-- OuterHost holds RootContent; RootContent is reparented into a borderless window for full screen. -->
    <Panel x:Name="OuterHost">
        <DockPanel x:Name="RootContent">
            <!-- Control bar (mirrors the speosilex.ro reference viewer); reflows onto further rows on
                 narrow panes so every button stays visible (like the Live Preview toolbar). -->
            <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,4">
              <DockPanel>
                <docking:PanelWindowControls DockPanel.Dock="Right" VerticalAlignment="Top" Margin="6,0,0,0" />
                <WrapPanel Orientation="Horizontal">
                    <!-- Model dropdown: every model produced by the active thconfig's export-model commands. -->
                    <TextBlock Text="{l:Loc M3D_Model}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="0,0,4,0" />
                    <ComboBox MinWidth="200" FontSize="11" Margin="0,0,6,2"
                              ItemsSource="{Binding Viewer.Models}"
                              SelectedItem="{Binding Viewer.SelectedModel, Mode=TwoWay}"
                              ToolTip.Tip="{l:Loc M3D_ModelTip}" />
                    <Button Content="{l:Loc Common_OpenEllipsis}" Click="OnOpen" FontSize="11" Padding="8,2" Margin="0,0,2,2"
                            ToolTip.Tip="{l:Loc M3D_OpenTip}" />
                    <Button Content="{l:Loc M3D_FullScreen}" Command="{Binding Viewer.ToggleFullscreenCommand}"
                            FontSize="11" Padding="6,2" Margin="0,0,2,2"
                            IsVisible="{Binding Viewer.IsFullscreen, Converter={x:Static cnv:BoolConverters.Not}}" />
                    <Button Content="{l:Loc M3D_ExitFullScreen}" Command="{Binding Viewer.ToggleFullscreenCommand}"
                            FontSize="11" Padding="6,2" Margin="0,0,2,2"
                            IsVisible="{Binding Viewer.IsFullscreen}" />
                    <Button Content="{l:Loc M3D_ResetView}" Command="{Binding Viewer.ResetViewCommand}" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                            ToolTip.Tip="{l:Loc M3D_ResetViewTip}" />
                    <Button Content="{l:Loc M3D_Defaults}" Command="{Binding Viewer.ResetControlsCommand}" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                            ToolTip.Tip="{l:Loc M3D_DefaultsTip}" />
                    <Button Content="{l:Loc Common_RefreshGlyph}" Command="{Binding Viewer.RefreshCommand}" FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <Button Content="DevTools" Command="{Binding Viewer.OpenDevToolsCommand}" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                            ToolTip.Tip="{l:Loc M3D_DevToolsTip}" />
                    <Button Content="{l:Loc Common_OpenExternally}" Command="{Binding Viewer.OpenExternallyCommand}"
                            IsEnabled="{Binding Viewer.HasModel}" FontSize="11" Padding="8,2" Margin="0,0,6,2" />

                    <Separator Width="1" Margin="3,2" Background="Gray" />

                    <!-- Orientation: plan + the four elevation profiles. -->
                    <TextBlock Text="{l:Loc M3D_View}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="0,0,4,0" />
                    <Button Content="{l:Loc M3D_Plan}"  Command="{Binding Viewer.SetViewCommand}" CommandParameter="plan"  FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <Button Content="N"     Command="{Binding Viewer.SetViewCommand}" CommandParameter="north" FontSize="11" Padding="6,2" Margin="0,0,2,2" ToolTip.Tip="{l:Loc M3D_ProfileN}" />
                    <Button Content="E"     Command="{Binding Viewer.SetViewCommand}" CommandParameter="east"  FontSize="11" Padding="6,2" Margin="0,0,2,2" ToolTip.Tip="{l:Loc M3D_ProfileE}" />
                    <Button Content="S"     Command="{Binding Viewer.SetViewCommand}" CommandParameter="south" FontSize="11" Padding="6,2" Margin="0,0,2,2" ToolTip.Tip="{l:Loc M3D_ProfileS}" />
                    <Button Content="W"     Command="{Binding Viewer.SetViewCommand}" CommandParameter="west"  FontSize="11" Padding="6,2" Margin="0,0,6,2" ToolTip.Tip="{l:Loc M3D_ProfileW}" />

                    <Separator Width="1" Margin="3,2" Background="Gray" />

                    <!-- Camera projection. -->
                    <Button Content="{l:Loc M3D_Perspective}"  Command="{Binding Viewer.SetCameraCommand}" CommandParameter="perspective"  FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <Button Content="{l:Loc M3D_Orthographic}" Command="{Binding Viewer.SetCameraCommand}" CommandParameter="orthographic" FontSize="11" Padding="6,2" Margin="0,0,6,2" />

                    <Separator Width="1" Margin="3,2" Background="Gray" />

                    <!-- Feature toggles (two-way to the view-model booleans). -->
                    <ToggleButton Content="{l:Loc M3D_Walls}"      IsChecked="{Binding Viewer.WallsOn, Mode=TwoWay}"           FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc M3D_Splays}"     IsChecked="{Binding Viewer.SplaysOn, Mode=TwoWay}"          FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc M3D_Surface}"    IsChecked="{Binding Viewer.SurfaceOn, Mode=TwoWay}"         FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc Browser_Tab_Stations}"   IsChecked="{Binding Viewer.StationsOn, Mode=TwoWay}"        FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc M3D_Labels}"     IsChecked="{Binding Viewer.LabelsOn, Mode=TwoWay}"          FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc M3D_Names}"      IsChecked="{Binding Viewer.NamesOn, Mode=TwoWay}"           FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc M3D_Box}"        IsChecked="{Binding Viewer.BoxOn, Mode=TwoWay}"             FontSize="11" Padding="6,2" Margin="0,0,2,2" ToolTip.Tip="{l:Loc M3D_BoxTip}" />
                    <ToggleButton Content="{l:Loc M3D_AutoRotate}" IsChecked="{Binding Viewer.AutoRotateOn, Mode=TwoWay}"      FontSize="11" Padding="6,2" Margin="0,0,2,2" />
                    <ToggleButton Content="{l:Loc M3D_Light}"      IsChecked="{Binding Viewer.DirectionalLightOn, Mode=TwoWay}" FontSize="11" Padding="6,2" Margin="0,0,2,2" ToolTip.Tip="{l:Loc M3D_LightTip}" />
                    <ToggleButton Content="{l:Loc M3D_Hud}"        IsChecked="{Binding Viewer.HudOn, Mode=TwoWay}"             FontSize="11" Padding="6,2" Margin="0,0,2,2" ToolTip.Tip="{l:Loc M3D_HudTip}" />
                    <ToggleButton Content="{l:Loc M3D_Menu}"       IsChecked="{Binding Viewer.SidebarOn, Mode=TwoWay}"         FontSize="11" Padding="6,2" Margin="0,0,6,2" ToolTip.Tip="{l:Loc M3D_MenuTip}" />

                    <Separator Width="1" Margin="3,2" Background="Gray" />

                    <!-- Color-by shading (selection remembered). -->
                    <TextBlock Text="{l:Loc M3D_ColorBy}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="0,0,4,0" />
                    <ToggleButton Content="{l:Loc M3D_Height}"      Command="{Binding Viewer.SetShadingCommand}" CommandParameter="height"      FontSize="11" Padding="6,2" Margin="0,0,2,2"
                                  IsChecked="{Binding Viewer.ShadingMode, Mode=OneWay, Converter={StaticResource ShadingEquals}, ConverterParameter=height}" />
                    <ToggleButton Content="{l:Loc Domain_Survey}"      Command="{Binding Viewer.SetShadingCommand}" CommandParameter="survey"      FontSize="11" Padding="6,2" Margin="0,0,2,2"
                                  IsChecked="{Binding Viewer.ShadingMode, Mode=OneWay, Converter={StaticResource ShadingEquals}, ConverterParameter=survey}" />
                    <ToggleButton Content="{l:Loc Browser_Col_Length}"      Command="{Binding Viewer.SetShadingCommand}" CommandParameter="length"      FontSize="11" Padding="6,2" Margin="0,0,2,2"
                                  IsChecked="{Binding Viewer.ShadingMode, Mode=OneWay, Converter={StaticResource ShadingEquals}, ConverterParameter=length}" />
                    <ToggleButton Content="{l:Loc M3D_Inclination}" Command="{Binding Viewer.SetShadingCommand}" CommandParameter="inclination" FontSize="11" Padding="6,2" Margin="0,0,2,2"
                                  IsChecked="{Binding Viewer.ShadingMode, Mode=OneWay, Converter={StaticResource ShadingEquals}, ConverterParameter=inclination}" />
                    <ToggleButton Content="{l:Loc M3D_Plain}"       Command="{Binding Viewer.SetShadingCommand}" CommandParameter="single"      FontSize="11" Padding="6,2" Margin="0,0,2,2"
                                  IsChecked="{Binding Viewer.ShadingMode, Mode=OneWay, Converter={StaticResource ShadingEquals}, ConverterParameter=single}" />
                </WrapPanel>
              </DockPanel>
            </Border>

            <!-- Bottom: an old-model notice (amber, when present) over the status line. -->
            <StackPanel DockPanel.Dock="Bottom">
                <TextBlock Text="{Binding Viewer.GeneratedNotice}" Foreground="#E65100" FontSize="11" Margin="6,2"
                           TextWrapping="Wrap"
                           IsVisible="{Binding Viewer.GeneratedNotice, Converter={x:Static cnv:StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="{Binding Viewer.Status}" Foreground="Gray" FontSize="11" Margin="6,2"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Grid>
                <!-- The NativeWebView is created in code-behind and added to this panel. -->
                <Panel x:Name="WebHost" />

                <!-- Fallback when the engine or vendored assets are unavailable (R5). -->
                <Border Background="#1e1e1e" IsVisible="{Binding Viewer.ShowFallback}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="420">
                        <TextBlock Text="{l:Loc M3D_Unavailable}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#d4d4d4" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Viewer.Status}" Foreground="#a0a0a0" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <Button Content="{l:Loc M3D_OpenModelExternal}" HorizontalAlignment="Center"
                                Command="{Binding Viewer.OpenExternallyCommand}" IsEnabled="{Binding Viewer.HasModel}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
