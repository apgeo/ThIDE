<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThIDE.ViewModels"
        xmlns:docking="using:ThIDE.ViewModels.Docking"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:conv="using:ThIDE.Converters"
        xmlns:qp="using:ThIDE.Views.QuickPick"
        xmlns:l="using:ThIDE.Resources"
        xmlns:ac="using:Avalonia.Data.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="800"
        x:Class="ThIDE.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1300" Height="800"
        Icon="/Assets/thide.ico"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Window.KeyBindings populated at runtime via IKeyboardShortcutService (Decision #29). -->

    <Window.Styles>
        <!-- Tab header tooltip + file-type tint. The DataContext of each document tab item is
             its FileDocumentViewModel. Dock renders document tabs as DocumentTabStripItem (a
             TabStripItem subclass), and an Avalonia bare type selector is exact-match only, so
             we use :is() to also match the subclass — otherwise neither setter applies (B1/#2).
             Tool tabs (no TabBrush/TabTooltip) simply resolve to null → default appearance. -->
        <Style Selector=":is(TabStripItem)" x:DataType="docking:FileDocumentViewModel">
            <Setter Property="ToolTip.Tip" Value="{Binding TabTooltip}" />
            <!-- Fade tint by file type (.th/.th2/.thconfig), task 2. -->
            <Setter Property="Background" Value="{Binding TabBrush}" />
        </Style>
        <!-- tab-management context menu on document tabs (pin / close others / close right /
             reopen). Reflection-bound (the tab item's DataContext is the FileDocumentViewModel,
             not the window VM). Scoped to DocumentTabStripItem so tool tabs are unaffected. -->
        <Style Selector="dock|DocumentTabStripItem">
            <Setter Property="ContextMenu">
                <ContextMenu x:CompileBindings="False">
                    <MenuItem Header="{l:Loc Tab_Pin}" Command="{Binding TogglePinCommand}" IsVisible="{Binding !IsPinned}" />
                    <MenuItem Header="{l:Loc Tab_Unpin}" Command="{Binding TogglePinCommand}" IsVisible="{Binding IsPinned}" />
                    <Separator />
                    <MenuItem Header="{l:Loc Tab_Close}" Command="{Binding CloseTabCommand}" />
                    <MenuItem Header="{l:Loc Tab_CloseOthers}" Command="{Binding CloseOtherTabsCommand}" />
                    <MenuItem Header="{l:Loc Tab_CloseRight}" Command="{Binding CloseTabsToRightCommand}" />
                    <MenuItem Header="{l:Loc Tab_CloseAll}" Command="{Binding CloseAllTabsCommand}" />
                    <Separator />
                    <MenuItem Header="{l:Loc Menu_File_ReopenTab}"
                              Command="{Binding $parent[Window].DataContext.ReopenClosedTabCommand}" />
                    <MenuItem Header="{l:Loc Tab_Float}" Command="{Binding FloatTabCommand}" />
                    <Separator />
                    <MenuItem Header="{l:Loc Gen_Reveal}" Command="{Binding RevealInFileManagerCommand}" />
                    <MenuItem Header="{l:Loc Ctx_CopyFull}" Command="{Binding CopyFullPathCommand}" />
                    <MenuItem Header="{l:Loc Ctx_CopyRel}" Command="{Binding CopyRelativePathCommand}" />
                    <MenuItem Header="{l:Loc Ctx_CopyName}" Command="{Binding CopyFileNameCommand}" />
                </ContextMenu>
            </Setter>
        </Style>
        <!-- Tab-strip arrow buttons scroll 3x faster (task 3). Dock renders the two end arrows
             of the document/tool tab strips as RepeatButtons bound to ScrollViewerLineCommand,
             so tripling their repeat rate (1/3 the interval) triples press-and-hold horizontal
             scroll speed. Scoped to the tab strips so editor/scrollbar RepeatButtons are unaffected. -->
        <Style Selector="dock|DocumentTabStrip RepeatButton">
            <Setter Property="Delay" Value="200" />
            <Setter Property="Interval" Value="33" />
        </Style>
        <Style Selector="dock|ToolTabStrip RepeatButton">
            <Setter Property="Delay" Value="200" />
            <Setter Property="Interval" Value="33" />
        </Style>

        <!-- Build icon pulses while a compile is running (class toggled by Build.IsBuilding). -->
        <Style Selector="PathIcon.buildPulse">
            <Style.Animations>
                <Animation Duration="0:0:0.9" IterationCount="INFINITE">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- #1: the compile/stop area pulses green while a build is running. -->
        <Style Selector="Border.compiling">
            <Setter Property="Background" Value="#3034A853" />
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Background" Value="#1A34A853" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Background" Value="#9934A853" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Medium icon buttons for the toolbar. -->
        <Style Selector="Button.tool">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tool > PathIcon">
            <Setter Property="Width" Value="17" />
            <Setter Property="Height" Value="17" />
        </Style>

        <!-- flat link-style segments for the @-qualified-name breadcrumb. -->
        <Style Selector="Button.crumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#1565C0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.crumb:pointerover">
            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Menu x:Name="MainMenu" DockPanel.Dock="Top">
            <MenuItem Header="{Binding MenuFile}">
                <MenuItem Header="{Binding MenuFileOpenFile}"   Command="{Binding OpenFileCommand}" />
                <MenuItem Header="{Binding MenuFileOpenThconfig}" Command="{Binding OpenThconfigCommand}" />
                <MenuItem Header="{Binding MenuFileOpenFolder}" Command="{Binding OpenFolderCommand}" />
                <Separator />
                <!-- Recent files, grouped per type (8 each), rebuilt in code-behind (#8). -->
                <MenuItem x:Name="RecentMenu" Header="{Binding MenuFileRecent}" />
                <!-- Recent working directories, rebuilt in code-behind. -->
                <MenuItem x:Name="RecentDirectoriesMenu" Header="{Binding MenuFileRecentDirectories}" />
                <!-- reopen the most-recently-closed tab. -->
                <MenuItem Header="{l:Loc Menu_File_ReopenTab}" InputGesture="Ctrl+Shift+T"
                          Command="{Binding ReopenClosedTabCommand}" />
                <Separator />
                <MenuItem Header="{Binding MenuFileExit}" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{Binding MenuView}">
                <MenuItem Header="{Binding MenuViewLanguage}">
                    <MenuItem Header="{Binding MenuViewLanguageEn}" Command="{Binding SwitchToEnglishCommand}" />
                    <MenuItem Header="{Binding MenuViewLanguageRo}" Command="{Binding SwitchToRomanianCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="{Binding MenuViewObjectBrowser}" Command="{Binding ToggleObjectBrowserCommand}" />
                <MenuItem Header="{Binding MenuViewWorkspace}" Command="{Binding ToggleWorkspaceExplorerCommand}" />
                <MenuItem Header="{l:Loc Menu_View_Project}" Command="{Binding ToggleProjectCommand}" />
                <MenuItem Header="{l:Loc Menu_View_Log}" Command="{Binding ToggleLogCommand}" />
                <MenuItem Header="{l:Loc Menu_View_LivePreview}" Command="{Binding ToggleLivePreviewCommand}"
                          IsVisible="{Binding LivePreviewEnabled}" />
                <MenuItem Header="{l:Loc Menu_View_MapViewer}" Command="{Binding ToggleMapViewerCommand}"
                          IsVisible="{Binding MapViewerEnabled}" />
                <MenuItem Header="{l:Loc Menu_View_Model3D}" Command="{Binding ToggleModel3DViewerCommand}"
                          IsVisible="{Binding Model3DViewerEnabled}" />
                <MenuItem Header="{l:Loc Menu_View_Structural}" Command="{Binding ToggleStructuralGeologyCommand}"
                          IsVisible="{Binding StructuralGeologyEnabled}" />
                <MenuItem Header="{Binding MenuViewDiagnostics}" Command="{Binding ToggleDiagnosticsCommand}" />
                <!-- document outline (hidden when the feature is disabled). -->
                <MenuItem Header="{l:Loc Menu_View_Outline}" Command="{Binding ToggleOutlineCommand}"
                          IsVisible="{Binding OutlineFeatureEnabled}" />
                <Separator />
                <MenuItem Header="{Binding MenuViewRelationalMap}" Click="OnRelationalMapClick" />
                <Separator />
                <MenuItem Header="{Binding MenuViewStrictParser}"
                          ToggleType="CheckBox"
                          IsChecked="{Binding StrictParserMode, Mode=TwoWay}" />
                <!-- whitespace/EOL/indent-guide render toggles (hidden when the feature is off). -->
                <Separator IsVisible="{Binding WhitespaceFeatureEnabled}" />
                <MenuItem Header="{l:Loc Menu_View_Whitespace}" IsVisible="{Binding WhitespaceFeatureEnabled}">
                    <MenuItem Header="{l:Loc Menu_View_ShowSpacesTabs}" ToggleType="CheckBox"
                              IsChecked="{Binding ShowWhitespace, Mode=TwoWay}" />
                    <MenuItem Header="{l:Loc Menu_View_ShowEol}" ToggleType="CheckBox"
                              IsChecked="{Binding ShowEndOfLine, Mode=TwoWay}" />
                    <MenuItem Header="{l:Loc Menu_View_ShowIndentGuides}" ToggleType="CheckBox"
                              IsChecked="{Binding ShowIndentGuides, Mode=TwoWay}" />
                </MenuItem>
                <!-- minimap toggle (hidden when the feature is off). -->
                <MenuItem Header="{l:Loc Menu_View_ShowMinimap}" ToggleType="CheckBox"
                          IsChecked="{Binding ShowMinimap, Mode=TwoWay}"
                          IsVisible="{Binding MinimapFeatureEnabled}" />
                <!-- open the active document side-by-side in a float window. -->
                <Separator IsVisible="{Binding SplitFeatureEnabled}" />
                <MenuItem Header="{l:Loc Menu_View_SplitEditor}" Command="{Binding SplitEditorCommand}"
                          IsVisible="{Binding SplitFeatureEnabled}" />
            </MenuItem>
            <!-- Edit menu mirrors the editor's right-click menu; enabled when a file is open (#11). -->
            <MenuItem Header="{Binding MenuEdit}" IsEnabled="{Binding HasStatusFile}">
                <MenuItem Header="{Binding MenuEditCut}"        InputGesture="Ctrl+X" Click="OnEditCut" />
                <MenuItem Header="{Binding MenuEditCopy}"       InputGesture="Ctrl+C" Click="OnEditCopy" />
                <MenuItem Header="{Binding MenuEditPaste}"      InputGesture="Ctrl+V" Click="OnEditPaste" />
                <MenuItem Header="{Binding MenuEditDelete}"     Click="OnEditDelete" />
                <Separator />
                <MenuItem Header="{Binding MenuEditSelectAll}" InputGesture="Ctrl+A" Click="OnEditSelectAll" />
                <Separator />
                <MenuItem Header="{Binding MenuEditUpper}"  Click="OnEditUpper" />
                <MenuItem Header="{Binding MenuEditLower}"  Click="OnEditLower" />
                <Separator />
                <MenuItem Header="{Binding MenuEditToggleComment}" InputGesture="Ctrl+OemQuestion" Click="OnEditToggleComment" />
                <MenuItem Header="{Binding MenuEditEncloseRegion}" InputGesture="Ctrl+Shift+R" Click="OnEditEncloseRegion" />
                <Separator />
                <MenuItem Header="{Binding MenuEditFoldAll}"   Click="OnEditFoldAll" />
                <MenuItem Header="{Binding MenuEditUnfoldAll}" Click="OnEditUnfoldAll" />
                <Separator />
                <MenuItem Header="{Binding MenuEditAddBookmark}" Click="OnEditAddBookmark" />
            </MenuItem>

            <!-- Search menu (#12). Find/Replace act on the focused editor; the rest are global. -->
            <MenuItem Header="{Binding MenuSearch}">
                <MenuItem Header="{Binding MenuSearchFind}"            InputGesture="Ctrl+F" Click="OnSearchFind" IsEnabled="{Binding HasStatusFile}" />
                <MenuItem Header="{Binding MenuSearchReplace}"         InputGesture="Ctrl+H" Click="OnSearchReplace" IsEnabled="{Binding HasStatusFile}" />
                <Separator />
                <MenuItem Header="{Binding MenuSearchFindInFiles}"    InputGesture="Ctrl+Shift+F" Click="OnSearchFindInFiles" />
                <MenuItem Header="{Binding MenuSearchReplaceInFiles}" InputGesture="Ctrl+Shift+H" Click="OnSearchReplaceInFiles" />
                <Separator />
                <MenuItem Header="{Binding MenuSearchGoTo}"     InputGesture="Ctrl+G" Click="OnSearchGoTo" IsEnabled="{Binding HasStatusFile}" />
                <Separator />
                <MenuItem Header="{Binding MenuSearchBookmarks}"    Click="OnBookmarksClick" />
            </MenuItem>
            <!-- Tools: import / GIS export / surface / scaffold -->
            <MenuItem Header="{l:Loc Menu_Tools}">
                <MenuItem Header="{l:Loc Menu_Tools_ImportSurvey}" Command="{Binding ImportSurveyCommand}" />
                <MenuItem Header="{l:Loc Menu_Tools_ImportDem}" Command="{Binding ImportDemSurfaceCommand}" />
                <MenuItem Header="{l:Loc Menu_Tools_ImportGpx}" Command="{Binding ImportGpxCommand}" />
                <Separator />
                <MenuItem Header="{l:Loc Menu_Tools_ExportEntrances}">
                    <MenuItem Header="KML…"      Command="{Binding ExportGisCommand}" CommandParameter="kml" />
                    <MenuItem Header="GeoJSON…"  Command="{Binding ExportGisCommand}" CommandParameter="geojson" />
                    <MenuItem Header="GPX…"      Command="{Binding ExportGisCommand}" CommandParameter="gpx" />
                    <MenuItem Header="CSV…"      Command="{Binding ExportGisCommand}" CommandParameter="csv" />
                </MenuItem>
                <!-- station / shot data tables. -->
                <MenuItem Header="{l:Loc Menu_Tools_ExportTable}">
                    <MenuItem Header="{l:Loc Browser_Tab_Stations}">
                        <MenuItem Header="CSV…"      Command="{Binding ExportTableCommand}" CommandParameter="stations|csv" />
                        <MenuItem Header="Markdown…" Command="{Binding ExportTableCommand}" CommandParameter="stations|markdown" />
                        <MenuItem Header="HTML…"     Command="{Binding ExportTableCommand}" CommandParameter="stations|html" />
                        <MenuItem Header="LaTeX…"    Command="{Binding ExportTableCommand}" CommandParameter="stations|latex" />
                    </MenuItem>
                    <MenuItem Header="{l:Loc Browser_Tab_Shots}">
                        <MenuItem Header="CSV…"      Command="{Binding ExportTableCommand}" CommandParameter="shots|csv" />
                        <MenuItem Header="Markdown…" Command="{Binding ExportTableCommand}" CommandParameter="shots|markdown" />
                        <MenuItem Header="HTML…"     Command="{Binding ExportTableCommand}" CommandParameter="shots|html" />
                        <MenuItem Header="LaTeX…"    Command="{Binding ExportTableCommand}" CommandParameter="shots|latex" />
                    </MenuItem>
                </MenuItem>
                <!-- one-click survey report. -->
                <MenuItem Header="{l:Loc Menu_Tools_GenReport}" Command="{Binding GenerateReportCommand}" />
                <Separator />
                <MenuItem Header="{l:Loc Menu_Tools_NewScrap}" Command="{Binding NewScrapScaffoldCommand}" />
                <Separator />
                <!-- calculators. -->
                <MenuItem Header="{l:Loc Menu_Tools_Calculators}">
                    <MenuItem Header="{l:Loc Menu_Tools_UnitConverter}" Click="OnUnitConverter" />
                    <MenuItem Header="{l:Loc Menu_Tools_CoordConverter}" Click="OnCoordinateConverter" />
                    <MenuItem Header="{l:Loc Menu_Tools_DeclinationCalc}" Click="OnDeclinationCalculator" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{Binding MenuBuild}">
                <MenuItem Header="{Binding MenuBuildBuild}"     InputGesture="F5"       Command="{Binding Build.BuildCommand}" />
                <MenuItem Header="{Binding MenuBuildCancel}"    InputGesture="Shift+F5" Command="{Binding Build.CancelCommand}" />
                <Separator />
                <!-- run a single export target from the active thconfig. -->
                <MenuItem Header="{l:Loc Menu_Build_Target}" IsEnabled="{Binding Build.HasExportTargets}"
                          ItemsSource="{Binding Build.ExportTargets}">
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" x:DataType="vm:BuildTarget"
                                      BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding Title}" />
                            <Setter Property="Command" Value="{Binding BuildCommand}" />
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <!-- composed quick export. -->
                <MenuItem Header="{l:Loc Menu_Build_QuickExport}" Command="{Binding Build.ShowQuickExportCommand}" />
                <Separator />
                <MenuItem Header="{Binding MenuBuildOpenLoch}"  InputGesture="F9"  Command="{Binding Build.OpenInLochCommand}" />
                <MenuItem Header="{Binding MenuBuildOpenAven}"  InputGesture="F10" Command="{Binding Build.OpenInAvenCommand}" />
                <!-- external round-trips. -->
                <MenuItem Header="{l:Loc Menu_Build_SurvexTools}" IsEnabled="{Binding Build.HasAvenArtifact}">
                    <MenuItem Header="{l:Loc Menu_Build_Dump3d}" Command="{Binding Build.Dump3dCommand}" />
                    <MenuItem Header="{l:Loc Menu_Build_Extend}" Command="{Binding Build.ExtendCommand}" />
                </MenuItem>
                <MenuItem Header="{l:Loc Menu_Build_TherionInfo}">
                    <MenuItem Header="{l:Loc Menu_Build_PrintVersion}" Command="{Binding Build.PrintTherionVersionCommand}" />
                    <MenuItem Header="{l:Loc Menu_Build_PrintEnv}" Command="{Binding Build.PrintTherionEnvironmentCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="{Binding MenuBuildOpenOutputFolder}" Command="{Binding Build.OpenLastOutputFolderCommand}" />
            </MenuItem>
            <!-- Settings: a top-level entry (renamed from File ▸ Preferences) that opens the
                 Preferences window directly (#7). -->
            <MenuItem Header="{Binding MenuSettings}" Click="OnPreferencesClick" />
            <!-- Help: About + the bundled Therion book (#1). -->
            <MenuItem Header="{Binding MenuHelp}">
                <MenuItem Header="{Binding MenuHelpWelcome}" Command="{Binding ShowWelcomeCommand}" />
                <MenuItem Header="{Binding MenuHelpUserGuide}" Command="{Binding OpenUserGuideCommand}" />
                <MenuItem Header="{Binding MenuHelpThbook}" Click="OnOpenThbook" />
                <Separator />
                <MenuItem Header="{Binding MenuHelpDebugInfo}" Click="OnDebugInfoClick" />
                <MenuItem Header="{Binding MenuHelpAbout}" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Icon toolbar: grouped action sections (File / Nav / Edit / Search / Build /
             Viewers / View / editor toggles), separated by thin dividers (#11). Wraps to a
             second row when the window is narrow. -->
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,3">
            <WrapPanel Orientation="Horizontal">
                <!-- File group -->
                <Button Classes="tool" Command="{Binding OpenFileCommand}" ToolTip.Tip="{l:Loc Tb_OpenFile}">
                    <PathIcon Data="{DynamicResource Icon.File}" />
                </Button>
                <Button Classes="tool" Command="{Binding OpenThconfigCommand}" ToolTip.Tip="{l:Loc Tb_OpenThconfig}">
                    <PathIcon Data="{DynamicResource Icon.Config}" />
                </Button>
                <Button Classes="tool" Command="{Binding OpenFolderCommand}" ToolTip.Tip="{l:Loc Tb_OpenFolder}">
                    <PathIcon Data="{DynamicResource Icon.FolderOpen}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- Navigation group -->
                <Button Classes="tool" Command="{Binding GoBackCommand}" ToolTip.Tip="{l:Tip Tb_Back}">
                    <PathIcon Data="{DynamicResource Icon.Back}" />
                </Button>
                <Button Classes="tool" Command="{Binding GoForwardCommand}" ToolTip.Tip="{l:Tip Tb_Forward}">
                    <PathIcon Data="{DynamicResource Icon.Forward}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <Button Classes="tool" Command="{Binding SaveCommand}" ToolTip.Tip="{l:Tip Tb_Save}">
                    <PathIcon Data="{DynamicResource Icon.Save}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- Edit group: enabled only when a file is open/focused (#11). -->
                <Button Classes="tool" Click="OnEditCut" IsEnabled="{Binding HasStatusFile}" ToolTip.Tip="{l:Tip Tb_Cut}">
                    <PathIcon Data="{DynamicResource Icon.Cut}" />
                </Button>
                <Button Classes="tool" Click="OnEditCopy" IsEnabled="{Binding HasStatusFile}" ToolTip.Tip="{l:Tip Tb_Copy}">
                    <PathIcon Data="{DynamicResource Icon.Copy}" />
                </Button>
                <Button Classes="tool" Click="OnEditPaste" IsEnabled="{Binding HasStatusFile}" ToolTip.Tip="{l:Tip Tb_Paste}">
                    <PathIcon Data="{DynamicResource Icon.Paste}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- Search group -->
                <Button Classes="tool" Click="OnSearchClick" ToolTip.Tip="{l:Tip Tb_FindInFiles}">
                    <PathIcon Data="{DynamicResource Icon.Search}" />
                </Button>
                <Button Classes="tool" Command="{Binding RenameSymbolCommand}" IsEnabled="{Binding HasStatusFile}" ToolTip.Tip="{l:Tip Tb_RenameSymbol}">
                    <PathIcon Data="{DynamicResource Icon.Rename}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- Go-to group: quick-open, command palette, and symbol search (workspace / document). -->
                <Button Classes="tool" Click="OnGoToFile" ToolTip.Tip="{l:Tip Tb_GoToFile}">
                    <PathIcon Data="{DynamicResource Icon.FileSearch}" />
                </Button>
                <Button Classes="tool" Click="OnGoToAction" ToolTip.Tip="{l:Tip Tb_GoToAction}">
                    <PathIcon Data="{DynamicResource Icon.Code}" />
                </Button>
                <Button Classes="tool" Click="OnGoToSymbolWorkspace" ToolTip.Tip="{l:Loc Tb_GoToSymbolWs}">
                    <PathIcon Data="{DynamicResource Icon.ManageSearch}" />
                </Button>
                <Button Classes="tool" Click="OnGoToSymbolDocument" ToolTip.Tip="{l:Loc Tb_GoToSymbolDoc}">
                    <PathIcon Data="{DynamicResource Icon.At}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- Tools group: import / export / report / scaffold / calculators (mirrors the Tools menu). -->
                <Button Classes="tool" ToolTip.Tip="{l:Loc Tb_Import}">
                    <PathIcon Data="{DynamicResource Icon.Import}" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{l:Loc Menu_Tools_ImportSurvey}" Command="{Binding ImportSurveyCommand}" />
                            <MenuItem Header="{l:Loc Menu_Tools_ImportDem}" Command="{Binding ImportDemSurfaceCommand}" />
                            <MenuItem Header="{l:Loc Menu_Tools_ImportGpx}" Command="{Binding ImportGpxCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Classes="tool" ToolTip.Tip="{l:Loc Tb_Export}">
                    <PathIcon Data="{DynamicResource Icon.Export}" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{l:Loc Menu_Tools_EntrancesFixed}">
                                <MenuItem Header="KML…"     Command="{Binding ExportGisCommand}" CommandParameter="kml" />
                                <MenuItem Header="GeoJSON…" Command="{Binding ExportGisCommand}" CommandParameter="geojson" />
                                <MenuItem Header="GPX…"     Command="{Binding ExportGisCommand}" CommandParameter="gpx" />
                                <MenuItem Header="CSV…"     Command="{Binding ExportGisCommand}" CommandParameter="csv" />
                            </MenuItem>
                            <MenuItem Header="{l:Loc Menu_Tools_StationTable}">
                                <MenuItem Header="CSV…"      Command="{Binding ExportTableCommand}" CommandParameter="stations|csv" />
                                <MenuItem Header="Markdown…" Command="{Binding ExportTableCommand}" CommandParameter="stations|markdown" />
                                <MenuItem Header="HTML…"     Command="{Binding ExportTableCommand}" CommandParameter="stations|html" />
                                <MenuItem Header="LaTeX…"    Command="{Binding ExportTableCommand}" CommandParameter="stations|latex" />
                            </MenuItem>
                            <MenuItem Header="{l:Loc Menu_Tools_ShotTable}">
                                <MenuItem Header="CSV…"      Command="{Binding ExportTableCommand}" CommandParameter="shots|csv" />
                                <MenuItem Header="Markdown…" Command="{Binding ExportTableCommand}" CommandParameter="shots|markdown" />
                                <MenuItem Header="HTML…"     Command="{Binding ExportTableCommand}" CommandParameter="shots|html" />
                                <MenuItem Header="LaTeX…"    Command="{Binding ExportTableCommand}" CommandParameter="shots|latex" />
                            </MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Classes="tool" Command="{Binding GenerateReportCommand}" ToolTip.Tip="{l:Loc Tb_GenReport}">
                    <PathIcon Data="{DynamicResource Icon.Th}" />
                </Button>
                <Button Classes="tool" Command="{Binding NewScrapScaffoldCommand}" ToolTip.Tip="{l:Loc Tb_NewScrap}">
                    <PathIcon Data="{DynamicResource Icon.Th2}" />
                </Button>
                <Button Classes="tool" ToolTip.Tip="{l:Loc Menu_Tools_Calculators}">
                    <PathIcon Data="{DynamicResource Icon.Timer}" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{l:Loc Menu_Tools_UnitConverter}" Click="OnUnitConverter" />
                            <MenuItem Header="{l:Loc Menu_Tools_CoordConverter}" Click="OnCoordinateConverter" />
                            <MenuItem Header="{l:Loc Menu_Tools_DeclinationCalc}" Click="OnDeclinationCalculator" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- Compile / Stop moved to the end of the toolbar (#1). -->
                <Button Classes="tool" Command="{Binding Build.OpenInLochCommand}"
                        IsEnabled="{Binding Build.HasLoxArtifact}" ToolTip.Tip="{l:Tip Tb_OpenLoch}">
                    <PathIcon Data="{DynamicResource Icon.External}" />
                </Button>
                <Button Classes="tool" Command="{Binding Build.OpenInAvenCommand}"
                        IsEnabled="{Binding Build.HasAvenArtifact}" ToolTip.Tip="{l:Tip Tb_OpenAven}">
                    <PathIcon Data="{DynamicResource Icon.Terrain}" />
                </Button>
                <!-- composed quick export + open the last output folder. -->
                <Button Classes="tool" Command="{Binding Build.ShowQuickExportCommand}" ToolTip.Tip="{l:Loc Menu_Build_QuickExport}">
                    <PathIcon Data="{DynamicResource Icon.Swap}" />
                </Button>
                <Button Classes="tool" Command="{Binding Build.OpenLastOutputFolderCommand}" ToolTip.Tip="{l:Loc Proj_OpenOutputFolder}">
                    <PathIcon Data="{DynamicResource Icon.FolderOutput}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- View group: focus the main tool panels (#11/#14). -->
                <Button Classes="tool" Command="{Binding ToggleObjectBrowserCommand}" ToolTip.Tip="{l:Loc Tool_ObjectBrowser}">
                    <PathIcon Data="{DynamicResource Icon.NodeGraph}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleWorkspaceExplorerCommand}" ToolTip.Tip="{l:Tip Menu_View_Workspace}">
                    <PathIcon Data="{DynamicResource Icon.Folder}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleDiagnosticsCommand}" ToolTip.Tip="{l:Tip Tool_Diagnostics}">
                    <PathIcon Data="{DynamicResource Icon.Warning}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleProjectCommand}" ToolTip.Tip="{l:Loc Menu_View_Project}">
                    <PathIcon Data="{DynamicResource Icon.Survey}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleLogCommand}" ToolTip.Tip="{l:Loc Menu_View_Log}">
                    <PathIcon Data="{DynamicResource Icon.Info}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleOutlineCommand}" ToolTip.Tip="{l:Loc Menu_View_Outline}"
                        IsVisible="{Binding OutlineFeatureEnabled}">
                    <PathIcon Data="{DynamicResource Icon.Sort}" />
                </Button>
                <Button Classes="tool" Click="OnRelationalMapClick" ToolTip.Tip="{l:Loc Tb_RelationalMap}">
                    <PathIcon Data="{DynamicResource Icon.AccountTree}" />
                </Button>
                <!-- Viewer panels, each gated by its feature setting (mirrors the View menu). -->
                <Button Classes="tool" Command="{Binding ToggleLivePreviewCommand}" ToolTip.Tip="{l:Loc Menu_View_LivePreview}"
                        IsVisible="{Binding LivePreviewEnabled}">
                    <PathIcon Data="{DynamicResource Icon.Eye}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleMapViewerCommand}" ToolTip.Tip="{l:Loc Menu_View_MapViewer}"
                        IsVisible="{Binding MapViewerEnabled}">
                    <PathIcon Data="{DynamicResource Icon.Map}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleModel3DViewerCommand}" ToolTip.Tip="{l:Loc Menu_View_Model3D}"
                        IsVisible="{Binding Model3DViewerEnabled}">
                    <PathIcon Data="{DynamicResource Icon.Cube}" />
                </Button>
                <Button Classes="tool" Command="{Binding ToggleStructuralGeologyCommand}" ToolTip.Tip="{l:Loc Menu_View_Structural}"
                        IsVisible="{Binding StructuralGeologyEnabled}">
                    <PathIcon Data="{DynamicResource Icon.Scrap}" />
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <ToggleButton Classes="tool" IsChecked="{Binding WordWrap, Mode=TwoWay}" ToolTip.Tip="{l:Loc Tb_WordWrap}">
                    <PathIcon Data="{DynamicResource Icon.WordWrap}" />
                </ToggleButton>
                <!-- Live validate-on-type push-switch: re-validate the whole project from unsaved buffers as you type. -->
                <ToggleButton Classes="tool" IsChecked="{Binding ValidateOnType, Mode=TwoWay}" ToolTip.Tip="{l:Loc Tb_ValidateOnType}">
                    <PathIcon Data="{DynamicResource Icon.Spellcheck}" />
                </ToggleButton>
                <!-- Push-switch: require a double-click (not a single click) to go to an identifier's declaration. -->
                <ToggleButton Classes="tool" IsChecked="{Binding RequireDoubleClickToNavigate, Mode=TwoWay}" ToolTip.Tip="{l:Loc Tb_DoubleClickNav}">
                    <PathIcon Data="{DynamicResource Icon.ClickNavigate}" />
                </ToggleButton>
                <Button Classes="tool" Click="OnToggleFullScreen" ToolTip.Tip="{l:Tip Tb_FullScreen}">
                    <PathIcon Data="{DynamicResource Icon.FullScreen}" />
                </Button>
                <!-- Layout controls (#16): float active document, reset to the default arrangement. -->
                <Button Classes="tool" ToolTip.Tip="{l:Loc Tb_Layout}">
                    <PathIcon Data="{DynamicResource Icon.Layout}" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{l:Loc Layout_FloatActive}"
                                      Command="{Binding FloatActiveDocumentCommand}" />
                            <Separator />
                            <MenuItem Header="{l:Loc Layout_Reset}"
                                      Command="{Binding ResetLayoutCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- notification center bell + unread badge + history flyout. -->
                <Button Classes="tool" Click="OnNotificationsClick" ToolTip.Tip="{l:Loc Tb_Notifications}">
                    <Panel>
                        <PathIcon Data="{DynamicResource Icon.Bell}" />
                        <Border IsVisible="{Binding HasUnreadNotifications}"
                                Background="#C62828" CornerRadius="7" MinWidth="14" Height="14"
                                Padding="3,0" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-3,-4,0">
                            <TextBlock Text="{Binding UnreadNotifications}" Foreground="White"
                                       FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Panel>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <Border Width="360" MaxHeight="420">
                                <DockPanel LastChildFill="True">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="4,2,2,6">
                                        <TextBlock Grid.Column="0" Text="{l:Loc Tb_Notifications}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="{l:Loc Common_Clear}" Padding="8,2"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding ClearNotificationsCommand}" />
                                    </Grid>
                                    <TextBlock DockPanel.Dock="Top" Text="{l:Loc Notif_Empty}"
                                               Foreground="Gray" FontSize="12" Margin="4,8"
                                               IsVisible="{Binding !HasNotificationHistory}" />
                                    <ScrollViewer>
                                        <ItemsControl ItemsSource="{Binding Notifications.History}"
                                                      x:CompileBindings="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#40808080" BorderThickness="0,0,0,1" Padding="4,6">
                                                        <StackPanel Spacing="2">
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="1" Text="{Binding TimeText}"
                                                                           Foreground="Gray" FontSize="11" Margin="6,0,0,0" />
                                                            </Grid>
                                                            <TextBlock Text="{Binding Message}" Foreground="Gray"
                                                                       FontSize="12" TextWrapping="Wrap" />
                                                            <Button Content="{Binding ActionLabel}" Padding="8,2" Margin="0,2,0,0"
                                                                    HorizontalAlignment="Left"
                                                                    Command="{Binding ActionCommand}"
                                                                    IsVisible="{Binding HasAction}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Separator Width="1" Margin="4,2" Background="Gray" />
                <!-- #1: compile + stop live at the end; the area pulses green while a build runs. -->
                <Border CornerRadius="6" Padding="2,0" Margin="2,0" VerticalAlignment="Center"
                        Classes.compiling="{Binding Build.IsBuilding}">
                    <StackPanel Orientation="Horizontal">
                        <Button Classes="tool" Command="{Binding Build.BuildCommand}" ToolTip.Tip="{l:Tip Tb_Compile}">
                            <PathIcon Data="{DynamicResource Icon.Build}" Foreground="#2E7D32"
                                      Classes.buildPulse="{Binding Build.IsBuilding}" />
                        </Button>
                        <!-- Stop is hidden while idle and only appears during a compilation (#6). -->
                        <Button Classes="tool" Command="{Binding Build.CancelCommand}"
                                IsVisible="{Binding Build.IsBuilding}" ToolTip.Tip="{l:Tip Tb_CancelCompile}">
                            <PathIcon Data="{DynamicResource Icon.Stop}" Foreground="#C62828" />
                        </Button>
                    </StackPanel>
                </Border>
                <!-- #3: status text + a clickable "N artifact(s)" link (success only). The status shows
                     the last error inline on failure; the full error is on the hover tooltip. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding Build.Status}" VerticalAlignment="Center" Foreground="Gray"
                               MaxWidth="520" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Build.LastError}" />
                    <TextBlock Text=" (" Foreground="Gray" VerticalAlignment="Center"
                               IsVisible="{Binding Build.HasArtifactLink}" />
                    <Button Classes="crumb" Content="{Binding Build.StatusArtifactCount}"
                            Command="{Binding Build.ShowOutputsCommand}"
                            IsVisible="{Binding Build.HasArtifactLink}" VerticalAlignment="Center"
                            ToolTip.Tip="{l:Loc Tb_ShowOutputs}" />
                    <TextBlock Text=")" Foreground="Gray" VerticalAlignment="Center"
                               IsVisible="{Binding Build.HasArtifactLink}" />
                </StackPanel>
                <!-- stage label + stepped progress, shown alongside the spinner. -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0,0,0"
                            IsVisible="{Binding Build.IsBuilding}">
                    <TextBlock Text="{Binding Build.CurrentPhase}" Foreground="#2E7D32" FontSize="11"
                               VerticalAlignment="Center" />
                    <ProgressBar Width="120" Height="6" Minimum="0" Maximum="1"
                                 Value="{Binding Build.PhaseProgress}" VerticalAlignment="Center" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Status bar (#10): transient messages on the left; open-file metrics on the right,
             grouped with thin separators. The full path is capped at 65% of the window width. -->
        <Border DockPanel.Dock="Bottom" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="6,2">
            <Border.Styles>
                <!-- Build spinner animation for the status bar (#4). -->
                <Style Selector="PathIcon.buildSpinner">
                    <Setter Property="RenderTransform"><RotateTransform /></Setter>
                    <Style.Animations>
                        <Animation Duration="0:0:1" IterationCount="INFINITE">
                            <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0" /></KeyFrame>
                            <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360" /></KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Border.Styles>
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="Gray"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                <!-- Build spinner: visible while building (#4). -->
                <PathIcon DockPanel.Dock="Left" Classes="buildSpinner"
                          Data="{DynamicResource Icon.Loading}"
                          Width="13" Height="13" Foreground="Gray" Margin="6,0,0,0"
                          RenderTransformOrigin="50%,50%"
                          IsVisible="{Binding Build.IsBuilding}"
                          ToolTip.Tip="{l:Loc Status_BuildInProgress}" />

                <!-- background-indexing indicator (object graph being (re)built off-thread). -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0"
                            VerticalAlignment="Center" IsVisible="{Binding IsIndexing}"
                            ToolTip.Tip="{l:Loc Status_BuildingGraph}">
                    <PathIcon Classes="buildSpinner" Data="{DynamicResource Icon.Loading}"
                              Width="12" Height="12" Foreground="Gray" RenderTransformOrigin="50%,50%" />
                    <TextBlock Text="{l:Loc Status_Indexing}" Foreground="Gray" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Build result indicator: green check / red X + optional warning count (#7). -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="3" Margin="6,0,0,0"
                            IsVisible="{Binding Build.HasBuildResult}" VerticalAlignment="Center">
                    <PathIcon Data="{DynamicResource Icon.CheckCircle}" Width="13" Height="13"
                              Foreground="#2E7D32" VerticalAlignment="Center"
                              IsVisible="{Binding Build.LastBuildSucceeded}"
                              ToolTip.Tip="{l:Loc Status_LastBuildOk}" />
                    <PathIcon Data="{DynamicResource Icon.ErrorCircle}" Width="13" Height="13"
                              Foreground="#C62828" VerticalAlignment="Center"
                              IsVisible="{Binding !Build.LastBuildSucceeded}"
                              ToolTip.Tip="{l:Loc Status_LastBuildFail}" />
                    <PathIcon Data="{DynamicResource Icon.Warning}" Width="12" Height="12"
                              Foreground="#E65100" VerticalAlignment="Center" Margin="3,0,0,0"
                              IsVisible="{Binding Build.LastBuildHasWarnings}" />
                    <TextBlock Text="{Binding Build.LastBuildWarningCount}" Foreground="#E65100"
                               FontSize="11" VerticalAlignment="Center"
                               IsVisible="{Binding Build.LastBuildHasWarnings}" />
                </StackPanel>

                <!-- clickable problems badge — opens the Diagnostics panel (F8 cycles). -->
                <Button DockPanel.Dock="Left" Background="Transparent" BorderThickness="0" Padding="6,0"
                        Margin="8,0,0,0" Command="{Binding ToggleDiagnosticsCommand}" Cursor="Hand"
                        IsVisible="{Binding Diagnostics.HasProblems}"
                        ToolTip.Tip="{l:Loc Status_OpenDiag}">
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <PathIcon Data="{DynamicResource Icon.ErrorCircle}" Width="12" Height="12" Foreground="#C62828" />
                        <TextBlock Text="{Binding Diagnostics.ErrorCount}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                        <PathIcon Data="{DynamicResource Icon.Warning}" Width="12" Height="12" Foreground="#E65100" Margin="5,0,0,0" />
                        <TextBlock Text="{Binding Diagnostics.WarningCount}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- clickable @-qualified-name breadcrumb of the token under the caret. -->
                <ItemsControl DockPanel.Dock="Left" Margin="12,0,0,0" VerticalAlignment="Center"
                              x:CompileBindings="False"
                              IsVisible="{Binding Breadcrumb.HasBreadcrumb}"
                              ItemsSource="{Binding Breadcrumb.Segments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Classes="crumb" Content="{Binding Text}"
                                        Command="{Binding $parent[ItemsControl].DataContext.Breadcrumb.NavigateCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="{Binding NavToken}" />
                                <TextBlock Text="›" Foreground="Gray" Margin="2,0" VerticalAlignment="Center"
                                           IsVisible="{Binding !IsLast}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- #1: clickable directory-segment breadcrumb of the active file's full path. Each
                     directory reveals + shows that folder in the Workspace Explorer; the file name is
                     plain text. Capped in width so the right-side metrics always fit. -->
                <ItemsControl DockPanel.Dock="Left" Margin="12,0,0,0" VerticalAlignment="Center"
                              x:CompileBindings="False" ClipToBounds="True"
                              IsVisible="{Binding HasStatusPath}"
                              ItemsSource="{Binding StatusPathCrumbs}"
                              MaxWidth="{Binding $parent[Window].Bounds.Width, Converter={x:Static conv:RatioConverter.Instance}, ConverterParameter=0.5}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Classes="crumb" Content="{Binding Name}"
                                        IsVisible="{Binding IsClickable}"
                                        Command="{Binding $parent[ItemsControl].DataContext.NavigatePathSegmentCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="{Binding Directory}" />
                                <TextBlock Text="{Binding Name}" Foreground="Gray" FontSize="11"
                                           VerticalAlignment="Center" IsVisible="{Binding !IsClickable}" />
                                <TextBlock Text="›" Foreground="Gray" Margin="2,0" VerticalAlignment="Center"
                                           IsVisible="{Binding !IsLast}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="0"
                            IsVisible="{Binding HasStatusFile}">
                    <StackPanel.Styles>
                        <!-- Thin separators between status groups. -->
                        <Style Selector="Border.statusSep">
                            <Setter Property="Width" Value="1" />
                            <Setter Property="Margin" Value="8,1" />
                            <Setter Property="Background" Value="#80808080" />
                        </Style>
                        <Style Selector="StackPanel.statusGroup > TextBlock">
                            <Setter Property="Foreground" Value="Gray" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="FontSize" Value="11" />
                        </Style>
                    </StackPanel.Styles>

                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{l:Loc Status_Length}" /><TextBlock Text="{Binding StatusLength}" />
                    </StackPanel>
                    <Border Classes="statusSep" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{l:Loc Status_Lines}" /><TextBlock Text="{Binding StatusLines}" />
                    </StackPanel>
                    <Border Classes="statusSep" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{l:Loc Status_Line}" /><TextBlock Text="{Binding StatusCaretLine}" />
                    </StackPanel>
                    <Border Classes="statusSep" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{l:Loc Status_Col}" /><TextBlock Text="{Binding StatusCaretCol}" />
                    </StackPanel>
                    <Border Classes="statusSep" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{l:Loc Status_Pos}" /><TextBlock Text="{Binding StatusCaretPos}" />
                    </StackPanel>
                    <!-- selection stats (chars / lines), shown only with an active selection. -->
                    <Border Classes="statusSep" IsVisible="{Binding HasSelection}" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3"
                                IsVisible="{Binding HasSelection}">
                        <TextBlock Text="{l:Loc Status_Sel}" /><TextBlock Text="{Binding SelectionChars}" />
                        <TextBlock Text="{l:Loc Status_Ch}" /><TextBlock Text="{Binding SelectionLines}" />
                        <TextBlock Text="{l:Loc Status_Ln}" />
                    </StackPanel>
                    <Border Classes="statusSep" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{Binding StatusEncoding}" />
                    </StackPanel>
                    <!-- Interpreted file type + parsed/not-parsed (#5). -->
                    <Border Classes="statusSep" />
                    <StackPanel Classes="statusGroup" Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="{Binding StatusFileType}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- VS-style docking host: documents (center) + dockable/floatable tool windows. -->
        <Grid>
            <dock:DockControl x:Name="Dock" Layout="{Binding Layout}" Factory="{Binding Factory}" />

            <!-- Quick-pick overlay (#3 Ctrl+P Go-to-File / #4 Ctrl+Shift+P commands). Shown when
                 MainWindowViewModel.QuickPick is set; its own DataContext is that VM. -->
            <qp:QuickPickOverlay DataContext="{Binding QuickPick}"
                                 IsVisible="{Binding Converter={x:Static ac:ObjectConverters.IsNotNull}}" />

            <!-- Ctrl+Tab document switcher overlay (#2): MRU list, opaque box, highlighted entry.
                 Shown while Ctrl is held; Ctrl-release activates the highlighted document. -->
            <Border IsVisible="{Binding DocumentSwitcher.IsOpen}" Background="#66000000">
                <Border Width="480" MaxHeight="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{DynamicResource SwBoxBg}"
                        BorderBrush="{DynamicResource SwBoxBorder}" BorderThickness="1"
                        CornerRadius="6" BoxShadow="0 8 24 0 #80000000" Padding="6">
                    <!-- Explicit, opaque, theme-aware brushes so the box never renders see-through
                         and the highlighted row is always clearly visible (#2). -->
                    <Border.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <SolidColorBrush x:Key="SwBoxBg" Color="#FFF3F3F3" />
                                    <SolidColorBrush x:Key="SwBoxBorder" Color="#FFB4B4B4" />
                                    <SolidColorBrush x:Key="SwSelBg" Color="#FF2563EB" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="Dark">
                                    <SolidColorBrush x:Key="SwBoxBg" Color="#FF2B2B2D" />
                                    <SolidColorBrush x:Key="SwBoxBorder" Color="#FF555558" />
                                    <SolidColorBrush x:Key="SwSelBg" Color="#FF3B82F6" />
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>
                        </ResourceDictionary>
                    </Border.Resources>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{l:Loc Sw_OpenDocs}"
                                   Foreground="Gray" FontSize="11" Margin="8,4,8,6" />
                        <ItemsControl ItemsSource="{Binding DocumentSwitcher.Items}">
                            <ItemsControl.Styles>
                                <Style Selector="Border.swItem">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="Border.swItem.selected">
                                    <Setter Property="Background" Value="{DynamicResource SwSelBg}" />
                                </Style>
                                <!-- White text on the blue selection for contrast. -->
                                <Style Selector="Border.swItem.selected TextBlock">
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:DocumentSwitcherItem">
                                    <Border Classes="swItem" Classes.selected="{Binding IsSelected}"
                                            CornerRadius="4" Padding="8,5" Margin="0,1">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <PathIcon Width="14" Height="14"
                                                      Data="{Binding IconKey, Converter={x:Static conv:ResourceKeyToGeometryConverter.Instance}}" />
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Border>

            <!-- Startup loading overlay with a spinning glyph (#14). -->
            <Border IsVisible="{Binding IsLoading}" Background="#66000000">
                <Border.Styles>
                    <Style Selector="PathIcon.spinner">
                        <Setter Property="RenderTransform">
                            <RotateTransform />
                        </Setter>
                        <Style.Animations>
                            <Animation Duration="0:0:1" IterationCount="INFINITE">
                                <KeyFrame Cue="0%">
                                    <Setter Property="RotateTransform.Angle" Value="0" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="RotateTransform.Angle" Value="360" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Border.Styles>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <PathIcon Classes="spinner" Data="{DynamicResource Icon.Loading}"
                              Width="44" Height="44" Foreground="White"
                              HorizontalAlignment="Center" RenderTransformOrigin="50%,50%" />
                    <TextBlock Text="{l:Loc Loading_Files}" Foreground="White" FontSize="14"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
