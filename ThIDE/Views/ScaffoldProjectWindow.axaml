<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThIDE.ViewModels"
        xmlns:l="using:ThIDE.Resources"
        x:Class="ThIDE.Views.ScaffoldProjectWindow"
        x:DataType="vm:ScaffoldProjectViewModel"
        x:CompileBindings="False"
        Title="{l:Loc Scaffold_Title}" Width="560" Height="640"
        WindowStartupLocation="CenterOwner" CanResize="True">
    <DockPanel Margin="16">
        <Border DockPanel.Dock="Bottom" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="{l:Loc Common_Cancel}" Click="OnCancel" MinWidth="80" />
                <Button Content="{l:Loc Scaffold_Create}" Click="OnCreate" IsDefault="True" MinWidth="120" />
            </StackPanel>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="12">
                <TextBlock Text="{l:Loc Scaffold_Intro}"
                           Foreground="Gray" TextWrapping="Wrap" FontSize="11" />

                <!-- Project identity -->
                <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Scaffold_ProjectName}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProjectName, Mode=TwoWay}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Scaffold_SurveyTitle}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Title, Mode=TwoWay}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:Loc Scaffold_SourceSurvey}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InnerSurveyName, Mode=TwoWay}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{l:Loc Scaffold_SourceFile}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SourceFileName, Mode=TwoWay}" />
                </Grid>

                <!-- Georeferencing -->
                <TextBlock Text="{l:Loc Scaffold_Geo}" FontWeight="SemiBold" />
                <TextBlock Text="{l:Loc Scaffold_GeoHint}" Foreground="Gray" TextWrapping="Wrap" FontSize="11" />
                <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Scaffold_Entrance}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EntranceStation, Mode=TwoWay}"
                             Watermark="{l:Loc Scaffold_EntranceWm}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Scaffold_Cs}" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding CoordinateSystems}"
                              SelectedItem="{Binding CoordinateSystem, Mode=TwoWay}" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:Loc Scaffold_Coord1}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FixCoord1, Mode=TwoWay}"
                             Watermark="{l:Loc Scaffold_Coord1Wm}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{l:Loc Scaffold_Coord2}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding FixCoord2, Mode=TwoWay}"
                             Watermark="{l:Loc Scaffold_Coord2Wm}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{l:Loc Scaffold_Altitude}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding FixAltitude, Mode=TwoWay}" />
                </Grid>

                <!-- Layout + tree options -->
                <TextBlock Text="{l:Loc Scaffold_Layout}" FontWeight="SemiBold" />
                <StackPanel Spacing="8">
                    <CheckBox Content="{l:Loc Scaffold_IncludeLayout}" IsChecked="{Binding IncludeLayout, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IncludeLayout}">
                        <TextBlock Text="{l:Loc Scaffold_Scale}" VerticalAlignment="Center" Width="132" />
                        <TextBlock Text="1 :" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding Scale, Mode=TwoWay}" Minimum="1" Maximum="1000000"
                                       Increment="100" Width="150" />
                    </StackPanel>
                    <CheckBox Content="{l:Loc Scaffold_Legend}" IsChecked="{Binding Legend, Mode=TwoWay}"
                              IsEnabled="{Binding IncludeLayout}" />
                    <CheckBox Content="{l:Loc Scaffold_GraphicsDir}" IsChecked="{Binding CreateGraphicsDir, Mode=TwoWay}" />
                </StackPanel>

                <!-- Export targets -->
                <TextBlock Text="{l:Loc Scaffold_Exports}" FontWeight="SemiBold" />
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8">
                    <ItemsControl ItemsSource="{Binding Exports}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Display}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Width="250" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
